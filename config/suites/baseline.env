# Baseline suite for this i7-7700 + Intel HD Graphics 630 machine.
#
# This file is shell-compatible on purpose: no YAML parser is required.
# Run with:
#   bench-suite-config baseline

EXPERIMENT=cpu-ai-kernel-baseline
LAB_WARMUPS=3
LAB_REPEATS=10
LAB_MONITOR_INTERVAL=1
LAB_MAX_TEMP_C=85

# Standard CPU baselines.
LAB_STREAM_ELEMENTS=33554432
LAB_STREAM_REPEATS=5
LAB_OPENBLAS_SIZE=1024
LAB_OPENBLAS_REPEATS=3
LAB_SYSBENCH_THREADS=8
LAB_SYSBENCH_TIME=10
OPENBLAS_NUM_THREADS=8
OMP_NUM_THREADS=8

# OpenCL baseline.
LAB_GEMM_SIZE=256
