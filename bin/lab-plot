#!/usr/bin/env python3
import argparse
import csv
import math
import sys
from datetime import datetime
from pathlib import Path

import matplotlib

matplotlib.use("Agg")
import matplotlib.pyplot as plt


LAB = Path.home() / "lab"


def latest_suite() -> Path:
    candidates = sorted(LAB.glob("*/suites/*/summary.csv"), key=lambda p: p.stat().st_mtime)
    if not candidates:
        raise SystemExit("No suite summary.csv found under ~/lab/*/suites")
    return candidates[-1].parent


def suite_path(value: str) -> Path:
    if value == "latest":
        return latest_suite()
    path = Path(value).expanduser()
    if path.is_file() and path.name == "summary.csv":
        path = path.parent
    if not path.exists():
        raise SystemExit(f"Suite not found: {path}")
    return path


def read_summary(suite: Path) -> list[dict[str, str]]:
    summary = suite / "summary.csv"
    if not summary.exists():
        raise SystemExit(f"Missing summary.csv: {summary}")
    with summary.open(newline="") as handle:
        return list(csv.DictReader(handle))


def floats(rows: list[dict[str, str]], metric: str) -> list[tuple[str, float]]:
    values = []
    for row in rows:
        raw = (row.get(metric) or "").strip()
        if not raw:
            continue
        try:
            value = float(raw)
        except ValueError:
            continue
        label = f"{row.get('workload', 'run')} #{row.get('run', '?')}"
        values.append((label, value))
    return values


def bar_panel(ax, rows: list[dict[str, str]], metric: str, title: str, ylabel: str) -> bool:
    values = floats(rows, metric)
    if not values:
        ax.axis("off")
        return False
    labels, numbers = zip(*values)
    colors = ["#4c78a8" if n >= 0 else "#d62728" for n in numbers]
    ax.bar(range(len(numbers)), numbers, color=colors, width=0.68)
    ax.set_title(title, fontsize=10)
    ax.set_ylabel(ylabel, fontsize=9)
    ax.set_xticks(range(len(labels)))
    ax.set_xticklabels(labels, rotation=25, ha="right", fontsize=8)
    ax.grid(axis="y", alpha=0.28)
    return True


def plot_summary(suite: Path, rows: list[dict[str, str]], out_dir: Path) -> Path | None:
    metrics = [
        ("scalar_fma_mean_s", "Scalar FMA", "seconds"),
        ("memory_walk_mean_s", "Memory Walk", "seconds"),
        ("sha256_mean_s", "SHA256", "seconds"),
        ("stream_triad_mb_s", "STREAM Triad", "MB/s"),
        ("openblas_gflops", "OpenBLAS GEMM", "GFLOP/s"),
        ("sysbench_events_s", "Sysbench CPU", "events/s"),
        ("opencl_bandwidth_gbs", "OpenCL Vector", "GB/s"),
        ("gemm_gflops", "OpenCL GEMM", "GFLOP/s"),
    ]

    fig, axes = plt.subplots(4, 2, figsize=(13, 15), constrained_layout=True)
    plotted = 0
    for ax, (metric, title, ylabel) in zip(axes.flat, metrics):
        if bar_panel(ax, rows, metric, title, ylabel):
            plotted += 1
    fig.suptitle(f"Suite Summary: {suite.name}", fontsize=14)
    if plotted == 0:
        plt.close(fig)
        return None
    out = out_dir / "summary-metrics.png"
    fig.savefig(out, dpi=140)
    plt.close(fig)
    return out


def read_monitor(path: Path) -> list[dict[str, str]]:
    try:
        with path.open(newline="") as handle:
            return list(csv.DictReader(handle))
    except OSError:
        return []


def parse_percent(value: str) -> float | None:
    value = value.strip().rstrip("%")
    if not value:
        return None
    try:
        return float(value)
    except ValueError:
        return None


def parse_float(value: str) -> float | None:
    if not value:
        return None
    try:
        number = float(value)
    except ValueError:
        return None
    if math.isnan(number) or math.isinf(number):
        return None
    return number


WORKLOAD_ORDER = {
    "cpu": 0,
    "standard-cpu": 1,
    "opencl-vector": 2,
    "opencl-gemm": 3,
}


def run_number(row: dict[str, str]) -> int:
    try:
        return int(row.get("run", "0"))
    except ValueError:
        return 0


def collect_monitor(rows: list[dict[str, str]]) -> list[dict[str, object]]:
    monitors = []
    for row in rows:
        run_dir = (row.get("run_dir") or "").strip()
        if not run_dir:
            continue
        path = Path(run_dir) / "monitor.csv"
        data = read_monitor(path)
        if data:
            workload = row.get("workload", "run")
            run = row.get("run", "?")
            monitors.append(
                {
                    "workload": workload,
                    "run": run,
                    "run_number": run_number(row),
                    "label": f"{workload} #{run}",
                    "data": data,
                }
            )
    monitors.sort(key=lambda item: (WORKLOAD_ORDER.get(str(item["workload"]), 99), int(item["run_number"])))
    return monitors


def elapsed_seconds(rows: list[dict[str, str]]) -> list[float]:
    base = None
    elapsed = []
    for i, row in enumerate(rows):
        raw = row.get("timestamp", "")
        try:
            ts = datetime.fromisoformat(raw)
            if base is None:
                base = ts
            elapsed.append((ts - base).total_seconds())
        except ValueError:
            elapsed.append(float(i))
    return elapsed


def sample_time(row: dict[str, str]) -> datetime | None:
    try:
        return datetime.fromisoformat(row.get("timestamp", ""))
    except ValueError:
        return None


def plot_temperature_by_run(monitors: list[dict[str, object]], out_dir: Path) -> Path | None:
    values = []
    for item in monitors:
        data = item["data"]
        temps = [parse_float(row.get("max_temp_c", "")) for row in data]  # type: ignore[index]
        temps = [temp for temp in temps if temp is not None]
        if temps:
            values.append((str(item["label"]), max(temps), str(item["workload"])))
    if not values:
        return None

    colors_by_workload = {
        "cpu": "#4c78a8",
        "standard-cpu": "#f58518",
        "opencl-vector": "#54a24b",
        "opencl-gemm": "#b279a2",
    }
    labels, temps, workloads = zip(*values)
    fig_width = max(12, len(values) * 0.34)
    fig, ax = plt.subplots(figsize=(fig_width, 5.5), constrained_layout=True)
    ax.bar(range(len(temps)), temps, color=[colors_by_workload.get(w, "#777777") for w in workloads], width=0.72)
    ax.set_title("Max Temperature by Run")
    ax.set_xlabel("run")
    ax.set_ylabel("C")
    ax.set_xticks(range(len(labels)))
    ax.set_xticklabels(labels, rotation=60, ha="right", fontsize=8)
    ax.grid(axis="y", alpha=0.28)
    ax.axhline(85, color="#d62728", linestyle="--", linewidth=1, label="LAB_MAX_TEMP_C=85")
    ax.legend(fontsize=8)
    out = out_dir / "monitor-temperature.png"
    fig.savefig(out, dpi=140)
    plt.close(fig)
    return out


def plot_monitor_timeline(
    monitors: list[dict[str, object]],
    out_dir: Path,
    key: str,
    filename: str,
    title: str,
    ylabel: str,
    parser,
) -> Path | None:
    samples_by_workload: dict[str, list[tuple[datetime, float]]] = {}
    for item in monitors:
        workload = str(item["workload"])
        data = item["data"]  # type: ignore[assignment]
        for row in data:  # type: ignore[union-attr]
            ts = sample_time(row)
            value = parser(row.get(key, ""))
            if ts is None or value is None:
                continue
            samples_by_workload.setdefault(workload, []).append((ts, value))

    all_times = [ts for samples in samples_by_workload.values() for ts, _ in samples]
    if not all_times:
        return None
    base = min(all_times)

    colors_by_workload = {
        "cpu": "#4c78a8",
        "standard-cpu": "#f58518",
        "opencl-vector": "#54a24b",
        "opencl-gemm": "#b279a2",
    }
    fig, ax = plt.subplots(figsize=(12, 5.5), constrained_layout=True)
    for workload in sorted(samples_by_workload, key=lambda w: WORKLOAD_ORDER.get(w, 99)):
        samples = sorted(samples_by_workload[workload], key=lambda pair: pair[0])
        xs = [(ts - base).total_seconds() for ts, _ in samples]
        ys = [value for _, value in samples]
        ax.plot(xs, ys, marker="o", linewidth=1.3, markersize=2.8, label=workload, color=colors_by_workload.get(workload))
    ax.set_title(title)
    ax.set_xlabel("seconds since first monitored sample in suite")
    ax.set_ylabel(ylabel)
    ax.grid(alpha=0.28)
    ax.legend(fontsize=8)
    if key == "max_temp_c":
        ax.axhline(85, color="#d62728", linestyle="--", linewidth=1, label="LAB_MAX_TEMP_C=85")
    out = out_dir / filename
    fig.savefig(out, dpi=140)
    plt.close(fig)
    return out


def plot_monitor(monitors: list[dict[str, object]], out_dir: Path) -> list[Path]:
    outputs = []
    if not monitors:
        return outputs

    temp_by_run = plot_temperature_by_run(monitors, out_dir)
    if temp_by_run:
        outputs.append(temp_by_run)

    specs = [
        ("max_temp_c", "monitor-temperature-timeline.png", "Temperature Timeline", "C", parse_float),
        ("cpu_scaling_mhz_percent", "monitor-cpu-scaling.png", "CPU Frequency Scaling Timeline", "%", parse_percent),
        ("load1", "monitor-load.png", "Load Average 1m Timeline", "load1", parse_float),
    ]

    for key, filename, title, ylabel, parser in specs:
        out = plot_monitor_timeline(monitors, out_dir, key, filename, title, ylabel, parser)
        if out:
            outputs.append(out)
    return outputs


def main() -> int:
    parser = argparse.ArgumentParser(description="Generate PNG plots for lab suite results.")
    parser.add_argument("suite", nargs="?", default="latest", help="suite directory, summary.csv, or 'latest'")
    args = parser.parse_args()

    suite = suite_path(args.suite)
    rows = read_summary(suite)
    out_dir = suite / "plots"
    out_dir.mkdir(parents=True, exist_ok=True)

    outputs = []
    summary_plot = plot_summary(suite, rows, out_dir)
    if summary_plot:
        outputs.append(summary_plot)
    outputs.extend(plot_monitor(collect_monitor(rows), out_dir))

    if not outputs:
        print(f"No plottable data found in {suite}", file=sys.stderr)
        return 1
    for output in outputs:
        print(output)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
