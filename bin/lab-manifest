#!/usr/bin/env python3
import hashlib
import json
import os
import platform
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


def run(cmd):
    try:
        p = subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=10)
        return {"cmd": cmd, "exit_code": p.returncode, "output": p.stdout.strip()}
    except Exception as exc:
        return {"cmd": cmd, "exit_code": -1, "output": str(exc)}


def sha256(path):
    p = Path(path)
    if not p.exists():
        return None
    h = hashlib.sha256()
    with p.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def command_path(name):
    return shutil.which(name)


def collect_tracked_files(bin_dir, config_dir):
    names = [
        "lab-safe-run",
        "bench-suite",
        "bench-suite-config",
        "summarize-suite",
        "suite-stats",
        "suite-compare",
        "lab-pipeline",
        "lab-tools-sync",
        "lab-tools-install",
    ]
    tracked = [bin_dir / name for name in names]
    tracked.extend(sorted(bin_dir.glob("bench-*")))
    tracked.extend(sorted(config_dir.glob("*.c")))
    tracked.extend(sorted(config_dir.glob("*.cu")))
    tracked.extend(sorted(config_dir.glob("*.swift")))
    for sub in ("suites", "containers", "templates", "pipelines"):
        tracked.extend(sorted((config_dir / sub).glob("*")))
    return [p for p in tracked if p.exists()]


def main():
    if len(sys.argv) < 5:
        print("Usage: lab-manifest RUN_DIR EXPERIMENT WORKDIR -- COMMAND...", file=sys.stderr)
        return 2
    run_dir = Path(sys.argv[1])
    experiment = sys.argv[2]
    workdir = sys.argv[3]
    if sys.argv[4] != "--":
        print("missing --", file=sys.stderr)
        return 2
    command = sys.argv[5:]

    bin_dir = Path.home() / "bin"
    config_dir = Path.home() / ".config" / "lab"
    tracked = collect_tracked_files(bin_dir, config_dir)

    manifest = {
        "schema_version": 1,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "host": platform.node(),
        "experiment": experiment,
        "workdir": workdir,
        "run_dir": str(run_dir),
        "command": command,
        "environment": {
            k: os.environ.get(k)
            for k in [
                "LAB_TIMEOUT",
                "LAB_CPUSET",
                "LAB_MAX_TEMP_C",
                "LAB_MONITOR_INTERVAL",
                "LAB_GEMM_SIZE",
                "LAB_INCLUDE_CUDA",
                "LAB_INCLUDE_UVM",
                "LAB_WORKLOADS",
                "LAB_UVM_MB",
                "LAB_UVM_PATTERN",
                "LAB_UVM_PASSES",
                "LAB_GEMV_SIZE",
                "LAB_SPMV_ROWS",
                "LAB_SPMV_NNZ_PER_ROW",
                "LAB_APPLE_ELEMENTS",
                "LAB_WARMUPS",
                "LAB_REPEATS",
                "LAB_STREAM_ELEMENTS",
                "LAB_STREAM_REPEATS",
                "LAB_OPENBLAS_SIZE",
                "LAB_OPENBLAS_REPEATS",
                "LAB_SYSBENCH_THREADS",
                "LAB_SYSBENCH_TIME",
                "EXPERIMENT",
                "OPENBLAS_NUM_THREADS",
                "OMP_NUM_THREADS",
                "OPENCL_PLATFORM_INDEX",
                "OPENCL_DEVICE_INDEX",
                "CUDA_VISIBLE_DEVICES",
            ]
            if os.environ.get(k) is not None
        },
        "system": {
            "platform": platform.platform(),
            "python": platform.python_version(),
            "uname": run(["uname", "-a"]),
            "cmdline": Path("/proc/cmdline").read_text(errors="replace").strip() if Path("/proc/cmdline").exists() else "",
            "lscpu": run(["lscpu"]),
            "governors": run(["sh", "-c", "cat /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor 2>/dev/null | sort -u"]),
            "smt": run(["sh", "-c", "cat /sys/devices/system/cpu/smt/active 2>/dev/null || true"]),
            "turbo": run(["sh", "-c", "cat /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null || true"]),
            "numa": run(["sh", "-c", "command -v numactl >/dev/null && numactl --hardware || true"]),
            "microcode": run(["sh", "-c", "grep -m1 '^microcode' /proc/cpuinfo 2>/dev/null || true"]),
        },
        "accelerators": {
            "opencl": run(["sh", "-c", "clinfo 2>/dev/null | sed -n '1,80p'"]),
            "nvidia": run(["sh", "-c", "command -v nvidia-smi >/dev/null && nvidia-smi || true"]),
            "nvidia_topology": run(["sh", "-c", "command -v nvidia-smi >/dev/null && nvidia-smi topo -m || true"]),
            "nvidia_clock_power_state": run(["sh", "-c", "command -v nvidia-smi >/dev/null && nvidia-smi --query-gpu=name,pci.bus_id,pstate,clocks.gr,clocks.mem,clocks.sm,power.limit,power.draw,persistence_mode,ecc.mode.current,mig.mode.current --format=csv,noheader,nounits 2>/dev/null || true"]),
            "nvidia_pcie": run(["sh", "-c", "command -v nvidia-smi >/dev/null && nvidia-smi --query-gpu=pcie.link.gen.current,pcie.link.gen.max,pcie.link.width.current,pcie.link.width.max --format=csv,noheader,nounits 2>/dev/null || true"]),
            "pci": run(["lspci", "-nn"]),
            "pci_verbose_gpu": run(["sh", "-c", "lspci -vv 2>/dev/null | sed -n '/VGA compatible controller\\|3D controller\\|Display controller/,+24p'"]),
        },
        "tool_versions": {
            name: run([path, "--version"]) if path and name in ["gcc", "python3"] else {"path": path}
            for name, path in {
                "gcc": command_path("gcc"),
                "python3": command_path("python3"),
                "clinfo": command_path("clinfo"),
                "nvidia-smi": command_path("nvidia-smi"),
                "nvcc": command_path("nvcc"),
                "sysbench": command_path("sysbench"),
            }.items()
        },
        "apt_packages": run(["sh", "-c", "dpkg-query -W -f='${Package}=${Version}\\n' clinfo intel-opencl-icd ocl-icd-opencl-dev opencl-headers intel-gpu-tools lm-sensors sysstat gcc python3 sysbench libopenblas-dev 2>/dev/null"]),
        "file_sha256": {str(p): sha256(p) for p in tracked},
    }
    run_dir.mkdir(parents=True, exist_ok=True)
    (run_dir / "manifest.json").write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
