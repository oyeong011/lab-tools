#!/usr/bin/env bash
set -euo pipefail

REPO="$HOME/lab-tools"
mkdir -p "$REPO"/{bin,config,notes}

copy_file() {
  local src="$1"
  local dst="$2"
  if [ -f "$src" ]; then
    mkdir -p "$(dirname "$dst")"
    cp -p "$src" "$dst"
  fi
}

for file in \
  ai-accel-check bench-cpu bench-openblas bench-opencl bench-opencl-gemm \
  bench-standard-cpu bench-stream bench-suite bench-suite-config bench-sysbench \
  bench-cuda-vector-add bench-cuda-gemm bench-cuda-uvm-access bench-cuda-gemv bench-cuda-spmv bench-cuda-gcn bench-apple-metal bench-apple-mps \
	  hw-report lab lab-acceptance-bundle lab-acceptance-collect lab-acceptance-verify lab-apple-smoke lab-doctor lab-handoff lab-host-acceptance lab-manifest lab-pin-system lab-profile lab-remote-acceptance lab-rtx-smoke lab-safe-run \
	  lab-pipeline lab-uvm-profile lab-validate lab-tools-sync lab-tools-install monitor-run \
	  nvidia-check nvml-check render-suite-report render-suite-html render-method-section render-repro-checklist \
	  sensor-snapshot suite-stats suite-compare summarize-suite thermal-check \
	  lab-index lab-archive lab-backup lab-plot lab-clean lab-container-build lab-container-run lab-nvidia-ready
do
  copy_file "$HOME/bin/$file" "$REPO/bin/$file"
done

for file in "$HOME"/.config/lab/*.c "$HOME"/.config/lab/*.cu "$HOME"/.config/lab/*.swift; do
  [ -e "$file" ] || continue
  copy_file "$file" "$REPO/config/$(basename "$file")"
done

mkdir -p "$REPO/config/suites" "$REPO/config/templates"
for file in "$HOME"/.config/lab/suites/*.env "$HOME"/.config/lab/suites/*.yaml; do
  [ -e "$file" ] || continue
	  copy_file "$file" "$REPO/config/suites/$(basename "$file")"
done
for file in "$HOME"/.config/lab/templates/*; do
  [ -e "$file" ] || continue
  copy_file "$file" "$REPO/config/templates/$(basename "$file")"
done
mkdir -p "$REPO/config/pipelines"
for file in "$HOME"/.config/lab/pipelines/*; do
  [ -e "$file" ] || continue
  copy_file "$file" "$REPO/config/pipelines/$(basename "$file")"
done
mkdir -p "$REPO/config/containers"
for file in "$HOME"/.config/lab/containers/*; do
  [ -e "$file" ] || continue
  copy_file "$file" "$REPO/config/containers/$(basename "$file")"
done

for file in "$HOME"/notes/ubuntu-lab-profile.md "$HOME"/notes/ubuntu-lab-guide.html "$HOME"/notes/research-pipeline.md; do
  [ -e "$file" ] || continue
  copy_file "$file" "$REPO/notes/$(basename "$file")"
done

if [ ! -f "$REPO/README.md" ]; then
  cat > "$REPO/README.md" <<'EOF'
# lab-tools

Lab benchmarking framework. See bin/lab-tools-install for setup on a new host.
EOF
fi

if [ ! -f "$REPO/.gitignore" ]; then
  cat > "$REPO/.gitignore" <<'EOF'
__pycache__/
*.pyc
*.o
*.out
_benchmarks/
_hardware/
runs/
*/runs/
*/suites/
!config/suites/
	!config/suites/*.env
	!config/suites/*.yaml
EOF
fi

if [ ! -d "$REPO/.git" ]; then
  git -C "$REPO" init
fi

git -C "$REPO" add -f README.md HANDOVER.md .gitignore bin config notes 2>/dev/null \
  || git -C "$REPO" add -f README.md .gitignore bin config notes
if git -C "$REPO" diff --cached --quiet; then
  printf 'lab-tools already up to date: %s\n' "$REPO"
else
  git -C "$REPO" commit -m "Update lab experiment tooling"
fi

git -C "$REPO" status --short
printf 'Synced lab tools repo: %s\n' "$REPO"
