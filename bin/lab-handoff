#!/usr/bin/env python3
"""Package a suite for off-machine reproduction (cloud or another host).

Bundles: the suite directory (full), every referenced run directory, the
matching Containerfile, the bin/ scripts in use, suite configs from
~/.config/lab, and a HANDOFF.md README. Output: a tar.zst (or tar.gz) under
~/lab/_handoffs/.

Usage:
  lab-handoff SUITE_DIR [--out PATH] [--include-runs|--no-include-runs]
"""
import argparse
import csv
import json
import os
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime
from pathlib import Path


HOME = Path.home()
LAB = HOME / "lab"
HANDOFF_DIR = LAB / "_handoffs"
TOOL_ROOT = Path(__file__).resolve().parents[1]

BIN_FILES = [
    "bench-cpu", "bench-openblas", "bench-opencl", "bench-opencl-gemm",
    "bench-standard-cpu", "bench-stream", "bench-suite", "bench-suite-config",
    "bench-sysbench", "bench-cuda-vector-add", "bench-cuda-gemm", "bench-cuda-uvm-access",
    "bench-cuda-gemv", "bench-cuda-spmv", "bench-cuda-gcn", "bench-apple-metal", "bench-apple-mps",
    "lab", "lab-manifest", "lab-pin-system", "lab-safe-run", "lab-profile", "lab-doctor", "lab-host-acceptance",
    "lab-tools-install", "lab-tools-sync", "lab-handoff", "lab-index", "lab-archive",
    "lab-backup", "lab-plot", "lab-clean",
    "lab-container-build", "lab-container-run", "lab-pipeline", "lab-rtx-smoke", "lab-apple-smoke", "lab-uvm-profile", "lab-validate",
    "render-suite-report", "render-suite-html", "render-method-section", "render-repro-checklist",
    "sensor-snapshot", "summarize-suite", "suite-stats", "suite-compare",
    "thermal-check", "ai-accel-check", "hw-report", "monitor-run",
    "nvml-check", "nvidia-check", "lab-nvidia-ready",
]

CONFIG_FILES = [
    "opencl-vector-add.c", "opencl-gemm.c", "stream-triad.c", "openblas-gemm.c",
    "cuda-vector-add.cu", "cuda-gemm.cu", "cuda-uvm-access.cu", "cuda-memory-kernels.cu",
    "apple-metal-vector.swift",
]


def referenced_runs(suite: Path):
    csv_path = suite / "summary.csv"
    runs = []
    if not csv_path.exists():
        return runs
    seen = set()
    with csv_path.open() as f:
        for row in csv.DictReader(f):
            rd = (row.get("run_dir") or "").strip()
            if rd and rd not in seen:
                seen.add(rd)
                p = Path(rd)
                if p.is_dir():
                    runs.append(p)
    return runs


def write_readme(staging: Path, suite: Path, runs, manifest_excerpt):
    md = staging / "HANDOFF.md"
    with md.open("w") as f:
        f.write(f"# Lab Handoff: `{suite.name}`\n\n")
        f.write(f"- Source host: `{os.uname().nodename}`\n")
        f.write(f"- Bundled at: `{datetime.now().isoformat(timespec='seconds')}`\n")
        f.write(f"- Bundled runs: {len(runs)}\n\n")
        f.write("## Layout\n\n")
        f.write("- `suite/` — full suite directory (summary.csv, stats.csv, monitor logs, reports)\n")
        f.write("- `runs/` — per-run directories referenced by summary.csv\n")
        f.write("- `bin/` — benchmark and pipeline scripts (drop into `~/bin` on the target host)\n")
        f.write("- `config/lab/` — OpenCL/CUDA/STREAM/OpenBLAS sources, suite configs, and pipeline matrices\n")
        f.write("- `config/lab/containers/` — CPU/OpenCL and CUDA container definitions\n")
        f.write("- `manifest-excerpt.json` — system snapshot for cross-host comparison\n\n")
        f.write("## Reproduction on a target host\n\n")
        f.write("```bash\n")
        f.write("bundle=\"${1:-<this-bundle>.tar.zst}\"\n")
        f.write("mkdir -p ~/lab-handoff\n")
        f.write("case \"$bundle\" in\n")
        f.write("  *.tar.zst) root=\"$(tar --zstd -tf \"$bundle\" | head -n 1 | cut -d/ -f1)\"; tar --zstd -xf \"$bundle\" -C ~/lab-handoff ;;\n")
        f.write("  *.tar.gz|*.tgz) root=\"$(tar -tzf \"$bundle\" | head -n 1 | cut -d/ -f1)\"; tar -xzf \"$bundle\" -C ~/lab-handoff ;;\n")
        f.write("  *) root=\"$(tar -tf \"$bundle\" | head -n 1 | cut -d/ -f1)\"; tar -xf \"$bundle\" -C ~/lab-handoff ;;\n")
        f.write("esac\n")
        f.write("cd ~/lab-handoff/\"$root\"\n")
        f.write("# Install scripts\n")
        f.write("mkdir -p ~/bin ~/.config/lab/suites ~/.config/lab/pipelines ~/.config/lab/containers\n")
        f.write("for f in bin/*; do install -m 755 \"$f\" ~/bin/; done\n")
        f.write("for f in config/lab/*.c config/lab/*.cu config/lab/*.swift; do [ -e \"$f\" ] && install -m 644 \"$f\" ~/.config/lab/; done\n")
        f.write("for f in config/lab/suites/*; do [ -e \"$f\" ] && install -m 644 \"$f\" ~/.config/lab/suites/; done\n")
        f.write("for f in config/lab/pipelines/*; do [ -e \"$f\" ] && install -m 644 \"$f\" ~/.config/lab/pipelines/; done\n")
        f.write("for f in config/lab/containers/*; do [ -e \"$f\" ] && install -m 644 \"$f\" ~/.config/lab/containers/; done\n")
        f.write("export PATH=\"$HOME/bin:$PATH\"\n")
        f.write("# Verify\n")
        f.write("lab-doctor\n")
        f.write("# Build container if podman available\n")
        f.write("lab-container-build cpu\n")
        f.write("# Re-run the same suite config used in the source\n")
        f.write("# (see HANDOFF.md `Original suite metadata` below)\n")
        f.write("```\n\n")
        f.write("## Original suite metadata\n\n")
        sm = suite / "summary.md"
        if sm.exists():
            f.write("```\n")
            f.write(sm.read_text(errors="replace"))
            f.write("\n```\n\n")
        if manifest_excerpt:
            f.write("## Source-host system summary\n\n")
            f.write("```\n")
            f.write(json.dumps(manifest_excerpt, indent=2, sort_keys=True))
            f.write("\n```\n")
    return md


def build_manifest_excerpt(runs):
    if not runs:
        return None
    manifest_path = runs[0] / "manifest.json"
    if not manifest_path.exists():
        return None
    try:
        full = json.load(manifest_path.open())
    except Exception:
        return None
    return {
        "host": full.get("host"),
        "experiment": full.get("experiment"),
        "system": {
            "platform": full.get("system", {}).get("platform"),
            "python": full.get("system", {}).get("python"),
            "uname": (full.get("system", {}).get("uname") or {}).get("output"),
            "lscpu": (full.get("system", {}).get("lscpu") or {}).get("output"),
            "governors": (full.get("system", {}).get("governors") or {}).get("output"),
        },
        "tool_versions": full.get("tool_versions"),
        "apt_packages": (full.get("apt_packages") or {}).get("output"),
    }


def stage(suite: Path, include_runs: bool, bundle_name: str):
    parent = Path(tempfile.mkdtemp(prefix="lab-handoff-"))
    staging = parent / bundle_name
    staging.mkdir()
    (staging / "suite").mkdir()
    for item in suite.iterdir():
        dst = staging / "suite" / item.name
        if item.is_dir():
            shutil.copytree(item, dst, symlinks=True)
        else:
            shutil.copy2(item, dst)

    runs = referenced_runs(suite)
    if include_runs and runs:
        (staging / "runs").mkdir()
        for run in runs:
            shutil.copytree(run, staging / "runs" / run.name, symlinks=True)

    bin_stage = staging / "bin"
    bin_stage.mkdir()
    for name in BIN_FILES:
        src = TOOL_ROOT / "bin" / name
        if not src.exists():
            src = HOME / "bin" / name
        if src.exists():
            shutil.copy2(src, bin_stage / name)
            (bin_stage / name).chmod(0o755)

    cfg_stage = staging / "config" / "lab"
    cfg_stage.mkdir(parents=True)
    for name in CONFIG_FILES:
        src = TOOL_ROOT / "config" / name
        if not src.exists():
            src = HOME / ".config" / "lab" / name
        if src.exists():
            shutil.copy2(src, cfg_stage / name)
    for sub in ("suites", "containers", "pipelines", "templates"):
        src_dir = TOOL_ROOT / "config" / sub
        if not src_dir.exists():
            src_dir = HOME / ".config" / "lab" / sub
        dst_dir = cfg_stage / sub
        dst_dir.mkdir()
        if src_dir.exists():
            for src in sorted(src_dir.iterdir()):
                if src.is_file():
                    shutil.copy2(src, dst_dir / src.name)

    manifest_excerpt = build_manifest_excerpt(runs)
    if manifest_excerpt:
        (staging / "manifest-excerpt.json").write_text(json.dumps(manifest_excerpt, indent=2, sort_keys=True))
    write_readme(staging, suite, runs, manifest_excerpt)

    return staging, runs


def archive(staging: Path, out_path: Path):
    out_path.parent.mkdir(parents=True, exist_ok=True)
    parent = staging.parent
    name = staging.name
    if shutil.which("zstd"):
        subprocess.run(["tar", "--zstd", "-cf", str(out_path), "-C", str(parent), name], check=True)
    else:
        out_path = out_path.with_suffix(".tar.gz")
        subprocess.run(["tar", "-czf", str(out_path), "-C", str(parent), name], check=True)
    sha = subprocess.run(["sha256sum", str(out_path)], capture_output=True, text=True, check=True).stdout
    (out_path.parent / (out_path.name + ".sha256")).write_text(sha)
    return out_path


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("suite_dir")
    parser.add_argument("--out")
    parser.add_argument("--include-runs", dest="include_runs", action="store_true", default=True)
    parser.add_argument("--no-include-runs", dest="include_runs", action="store_false")
    args = parser.parse_args()

    suite = Path(args.suite_dir).resolve()
    if not suite.is_dir():
        print(f"Not a directory: {suite}", file=sys.stderr)
        return 2

    experiment = suite.parents[1].name if len(suite.parents) >= 2 else "unknown"

    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    bundle_name = f"{experiment}-{suite.name}-handoff-{stamp}"
    if args.out:
        out_path = Path(args.out)
    else:
        out_path = HANDOFF_DIR / f"{bundle_name}.tar.zst"

    staging, runs = stage(suite, args.include_runs, bundle_name)
    try:
        final = archive(staging, out_path)
        print(final)
        print(f"runs={len(runs)} include_runs={args.include_runs}")
    finally:
        shutil.rmtree(staging.parent, ignore_errors=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
