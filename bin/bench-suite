#!/usr/bin/env bash
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
EXPERIMENT="${1:-cpu-ai-kernel-baseline}"
REPEATS="${2:-${LAB_REPEATS:-3}}"
WARMUPS="${LAB_WARMUPS:-0}"
SHUFFLE="${LAB_SHUFFLE:-1}"
SHUFFLE_SEED="${LAB_SHUFFLE_SEED:-$(date +%s)}"
SUITE_DIR="$LAB_HOME/$EXPERIMENT/suites/$(date +%Y%m%d-%H%M%S-%N)-$$"
PATH="$HOME/bin:$PATH"

case "$EXPERIMENT" in
  *[!A-Za-z0-9._-]*|'')
    printf 'Invalid experiment name: %s\n' "$EXPERIMENT" >&2
    exit 2
    ;;
esac

WORKLOADS=(cpu standard-cpu opencl opencl-gemm)
declare -A WORKLOAD_CMD=(
  [cpu]=bench-cpu
  [standard-cpu]=bench-standard-cpu
  [opencl]=bench-opencl
  [opencl-gemm]=bench-opencl-gemm
)
declare -A WORKLOAD_LABEL=(
  [cpu]="CPU"
  [standard-cpu]="Standard CPU baseline"
  [opencl]="OpenCL"
  [opencl-gemm]="OpenCL GEMM"
)

mkdir -p "$SUITE_DIR"

pinned_state="$(lab-pin-system check 2>/dev/null && printf yes || printf no)"

{
  printf '# Bench Suite\n\n'
  printf -- '- Experiment: `%s`\n' "$EXPERIMENT"
  printf -- '- Warmups: `%s`\n' "$WARMUPS"
  printf -- '- Repeats: `%s`\n' "$REPEATS"
  printf -- '- Shuffle: `%s` (seed=`%s`)\n' "$SHUFFLE" "$SHUFFLE_SEED"
  printf -- '- System pinned: `%s`\n' "$pinned_state"
  printf -- '- Started: `%s`\n' "$(date --iso-8601=seconds)"
} > "$SUITE_DIR/summary.md"

hw-report > "$SUITE_DIR/hardware-report-path.txt"
ai-accel-check > "$SUITE_DIR/ai-accel-check.txt"
sensor-snapshot > "$SUITE_DIR/sensors-start.txt" || true

run_one() {
  local workload="$1" idx="$2" tag="$3"
  local cmd="${WORKLOAD_CMD[$workload]}"
  local label="${WORKLOAD_LABEL[$workload]}"
  local log="$SUITE_DIR/${tag}${workload}-run-${idx}.log"
  printf '%s%s run %s/%s\n' "${tag}" "$label" "$idx" "$REPEATS" | tee -a "$SUITE_DIR/summary.md"
  if lab-safe-run "$EXPERIMENT" -- "$cmd" > "$log" 2>&1; then
    printf -- '- %s%s run %s: ok\n' "${tag}" "$label" "$idx" >> "$SUITE_DIR/summary.md"
  else
    printf -- '- %s%s run %s: failed, see `%s`\n' "${tag}" "$label" "$idx" "$(basename "$log")" >> "$SUITE_DIR/summary.md"
  fi
}

if [ "$WARMUPS" -gt 0 ]; then
  for i in $(seq 1 "$WARMUPS"); do
    for w in cpu opencl opencl-gemm; do
      lab-safe-run "$EXPERIMENT" -- "${WORKLOAD_CMD[$w]}" > "$SUITE_DIR/warmup-${w}-${i}.log" 2>&1 || true
    done
  done
fi

ORDER_FILE="$SUITE_DIR/execution-order.csv"
printf 'order,workload,repeat\n' > "$ORDER_FILE"

python3 - "$SHUFFLE" "$SHUFFLE_SEED" "$REPEATS" "$ORDER_FILE" "${WORKLOADS[@]}" <<'PY' >> /dev/null
import random, sys

shuffle = sys.argv[1] == "1"
seed = int(sys.argv[2])
repeats = int(sys.argv[3])
order_file = sys.argv[4]
workloads = sys.argv[5:]

plan = [(w, i) for i in range(1, repeats + 1) for w in workloads]
if shuffle:
    rng = random.Random(seed)
    rng.shuffle(plan)

with open(order_file, "a") as f:
    for idx, (w, r) in enumerate(plan, start=1):
        f.write(f"{idx},{w},{r}\n")
PY

while IFS=, read -r order workload repeat; do
  [ "$order" = order ] && continue
  run_one "$workload" "$repeat" ""
done < "$ORDER_FILE"

sensor-snapshot > "$SUITE_DIR/sensors-end.txt" || true
summarize-suite "$SUITE_DIR" > "$SUITE_DIR/summary-csv-path.txt"
suite-stats "$SUITE_DIR" > "$SUITE_DIR/stats-csv-path.txt"
render-suite-report "$SUITE_DIR" > "$SUITE_DIR/report-path.txt"
render-method-section "$SUITE_DIR" > "$SUITE_DIR/method-md-path.txt" 2>/dev/null || true
render-repro-checklist "$SUITE_DIR" > "$SUITE_DIR/repro-md-path.txt" 2>/dev/null || true
{
  printf -- '- Finished: `%s`\n' "$(date --iso-8601=seconds)"
  printf -- '- CSV: `%s`\n' "$SUITE_DIR/summary.csv"
  printf -- '- Stats: `%s`\n' "$SUITE_DIR/stats.csv"
  printf -- '- Report: `%s`\n' "$SUITE_DIR/report.md"
  printf -- '- Order: `%s`\n' "$ORDER_FILE"
} >> "$SUITE_DIR/summary.md"
printf 'Suite complete: %s\n' "$SUITE_DIR"
