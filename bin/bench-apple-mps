#!/usr/bin/env python3
import os
import sys
import time


def main():
    if sys.platform != "darwin":
        print("bench-apple-mps requires macOS.", file=sys.stderr)
        return 127
    try:
        import torch
    except ImportError:
        print("PyTorch is not installed; install a build with MPS support to run this benchmark.", file=sys.stderr)
        return 127
    if not getattr(torch.backends, "mps", None) or not torch.backends.mps.is_available():
        print("PyTorch MPS backend is not available on this host.", file=sys.stderr)
        return 127

    n = int(sys.argv[1]) if len(sys.argv) > 1 else int(os.environ.get("LAB_APPLE_ELEMENTS", "16777216"))
    if n <= 0:
        print("element count must be positive", file=sys.stderr)
        return 2
    device = torch.device("mps")
    a = torch.arange(n, dtype=torch.float32, device=device)
    b = torch.arange(n, dtype=torch.float32, device=device) * 0.5
    torch.mps.synchronize()
    start = time.perf_counter()
    c = a + b
    torch.mps.synchronize()
    elapsed = time.perf_counter() - start
    sample = c[: min(n, 1024)].cpu()
    ref = (torch.arange(sample.numel(), dtype=torch.float32) * 1.5)
    max_error = (sample - ref).abs().max().item() if sample.numel() else 0.0
    gbps = (n * 3 * 4) / elapsed / 1.0e9
    print("Device: Apple MPS")
    print(f"Elements: {n}")
    print(f"Kernel time: {elapsed:.6f} s")
    print(f"Device approx bandwidth: {gbps:.6f} GB/s")
    print(f"Max error: {max_error:.6f}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
