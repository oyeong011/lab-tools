#!/usr/bin/env bash
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
RUN=0
UVM_PROFILE=0
DRY_RUN=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PATH="$SCRIPT_DIR:$HOME/bin:$PATH"

usage() {
  cat <<'EOF'
Usage:
  lab-host-acceptance [--run] [--uvm-profile] [--dry-run]

Creates a host-level acceptance artifact under ~/lab/_acceptance. The default
checks install/config/readiness. With --run it also runs the profile-specific
smoke benchmark. With --uvm-profile on CUDA hosts, it captures a small Nsight
Systems UVM profile.
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --run) RUN=1; shift ;;
    --uvm-profile) UVM_PROFILE=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help|help) usage; exit 0 ;;
    *) usage >&2; exit 2 ;;
  esac
done

slug_host() {
  hostname 2>/dev/null | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//'
}

profile="$(lab-profile 2>/dev/null || printf cpu)"
host="$(slug_host)"
[ -n "$host" ] || host=unknown-host
stamp="$(date +%Y%m%d-%H%M%S)"
out_dir="$LAB_HOME/_acceptance/${host}-${profile}-${stamp}-$$"

steps=()
add_step() {
  steps+=("$1"$'\t'"$2")
}

config_path() {
  local rel="$1"
  if [ -f "$SCRIPT_DIR/../config/$rel" ]; then
    printf '%s\n' "$SCRIPT_DIR/../config/$rel"
  else
    printf '%s\n' "$HOME/.config/lab/$rel"
  fi
}

quote_arg() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\"'\"'/g")"
}

matrix_config="$(config_path pipelines/research-matrix.yaml)"

add_step "profile" "lab-profile && lab-profile detect"
add_step "doctor" "lab-doctor"
add_step "matrix-validate" "lab-validate matrix $(quote_arg "$matrix_config")"
add_step "baseline-config" "bench-suite-config --dry-run baseline.yaml"
add_step "pipeline-cpu-plan" "lab-pipeline plan consumer-accelerator-baseline --profile cpu --dry-run"

case "$profile" in
  cuda)
    add_step "rtx-smoke-dry" "lab-rtx-smoke"
    add_step "forest-uvm-config" "bench-suite-config --dry-run forest-uvm.yaml"
    add_step "memory-kernels-config" "bench-suite-config --dry-run memory-kernels.yaml"
    add_step "memory-kernels-sweep-plan" "lab-pipeline plan memory-hierarchy-pim --profile cuda --sweep --dry-run"
    if [ "$RUN" -eq 1 ]; then
      add_step "rtx-smoke-run" "LAB_RTX_SMOKE_UVM_MB=${LAB_RTX_SMOKE_UVM_MB:-512} lab-rtx-smoke --run"
    fi
    if [ "$UVM_PROFILE" -eq 1 ]; then
      add_step "uvm-profile-small" "lab-uvm-profile --pattern ls --mb ${LAB_ACCEPTANCE_UVM_MB:-512} --passes 1"
    fi
    ;;
  apple)
    add_step "apple-smoke-dry" "lab-apple-smoke"
    if [ "$RUN" -eq 1 ]; then
      add_step "apple-smoke-run" "LAB_APPLE_ELEMENTS=${LAB_APPLE_ELEMENTS:-1024} lab-apple-smoke --run --run-mps"
    fi
    ;;
  *)
    add_step "cpu-quick-config" "bench-suite-config --dry-run quick.yaml"
    if [ "$RUN" -eq 1 ]; then
      add_step "cpu-smoke-run" "bench-opencl"
    fi
    ;;
esac

if [ "$DRY_RUN" -eq 1 ]; then
  printf 'Acceptance dry-run profile=%s\n' "$profile"
  for item in "${steps[@]}"; do
    name="${item%%$'\t'*}"
    cmd="${item#*$'\t'}"
    printf 'DRY %-28s %s\n' "$name" "$cmd"
  done
  exit 0
fi

mkdir -p "$out_dir"
status_tsv="$out_dir/status.tsv"
printf 'name\tstatus\texit_code\tlog\tcommand\n' > "$status_tsv"

failures=0
for item in "${steps[@]}"; do
  name="${item%%$'\t'*}"
  cmd="${item#*$'\t'}"
  log="$out_dir/${name}.log"
  printf '== %s ==\n%s\n' "$name" "$cmd" | tee "$log" >/dev/null
  set +e
  bash -c "$cmd" >> "$log" 2>&1
  rc=$?
  set -e
  if [ "$name" = "uvm-profile-small" ] && [ "$rc" -eq 0 ]; then
    profile_stage="$out_dir/profiles"
    mkdir -p "$profile_stage"
    report="$(sed -n 's/^nsys_report=//p' "$log" | tail -n 1)"
    stats_dir="$(sed -n 's/^stats_dir=//p' "$log" | tail -n 1)"
    if [ -n "$report" ] && [ -f "$report" ]; then
      cp -p "$report" "$profile_stage/"
      printf 'copied_nsys_report=%s\n' "$profile_stage/$(basename "$report")" >> "$log"
    else
      printf 'missing nsys_report artifact: %s\n' "${report:-<empty>}" >> "$log"
      rc=1
    fi
    if [ -n "$stats_dir" ] && [ -d "$stats_dir" ]; then
      cp -R "$stats_dir" "$profile_stage/"
      printf 'copied_stats_dir=%s\n' "$profile_stage/$(basename "$stats_dir")" >> "$log"
    fi
  fi
  if [ "$rc" -eq 0 ]; then
    status=ok
  else
    status=fail
    failures=$((failures + 1))
  fi
  printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$status" "$rc" "$(basename "$log")" "$cmd" >> "$status_tsv"
  printf '%-28s %s\n' "$name" "$status"
done

python3 - "$out_dir" "$profile" "$failures" "$SCRIPT_DIR" <<'PY'
import csv, hashlib, json, os, subprocess, sys
from datetime import datetime
from pathlib import Path

out_dir = Path(sys.argv[1])
profile = sys.argv[2]
failures = int(sys.argv[3])
script_dir = Path(sys.argv[4]).resolve()

def sha256_file(path):
    h = hashlib.sha256()
    with Path(path).open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def git_value(repo, *args):
    try:
        return subprocess.check_output(["git", "-C", str(repo), *args], text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return ""

def should_hash_bin(path):
    name = path.name
    return (
        name.startswith("lab-")
        or name.startswith("bench-")
        or name.startswith("suite-")
        or name.startswith("render-")
        or name in {
            "lab", "ai-accel-check", "nvidia-check", "nvml-check", "summarize-suite",
            "hw-report", "monitor-run", "thermal-check", "sensor-snapshot",
        }
    )

def provenance(script_dir):
    repo = script_dir.parent
    file_hashes = {}
    if script_dir.is_dir():
        for path in sorted(script_dir.iterdir()):
            if path.is_file() and should_hash_bin(path):
                file_hashes[f"bin/{path.name}"] = sha256_file(path)
    checkout_config = repo / "config"
    installed_config = Path.home() / ".config" / "lab"
    if checkout_config.is_dir():
        config_root = checkout_config
        config_prefix = "config"
    else:
        config_root = installed_config
        config_prefix = "config/lab"
    if config_root.is_dir():
        for path in sorted(config_root.rglob("*")):
            if path.is_file():
                file_hashes[f"{config_prefix}/{path.relative_to(config_root).as_posix()}"] = sha256_file(path)
    commit = git_value(repo, "rev-parse", "HEAD")
    tree = git_value(repo, "rev-parse", "HEAD^{tree}") if commit else ""
    dirty = bool(git_value(repo, "status", "--porcelain")) if commit else None
    return {
        "schema_version": 1,
        "generated_at": datetime.now().isoformat(timespec="seconds"),
        "source_layout": "checkout" if checkout_config.is_dir() else "installed",
        "script_dir": str(script_dir),
        "git_commit": commit or "unknown",
        "git_tree": tree or "unknown",
        "git_dirty": dirty,
        "file_sha256": file_hashes,
    }

with (out_dir / "status.tsv").open(newline="") as f:
    rows = list(csv.DictReader(f, delimiter="\t"))
data = {
    "schema_version": 1,
    "generated_at": datetime.now().isoformat(timespec="seconds"),
    "host": os.uname().nodename,
    "profile": profile,
    "status": "ok" if failures == 0 else "failed",
    "failures": failures,
    "steps": rows,
    "tool_provenance": provenance(script_dir),
}
(out_dir / "acceptance.json").write_text(json.dumps(data, indent=2) + "\n")
(out_dir / "README.md").write_text(
    "# Lab Host Acceptance\n\n"
    f"- Host: `{data['host']}`\n"
    f"- Profile: `{profile}`\n"
    f"- Status: `{data['status']}`\n"
    f"- Failures: `{failures}`\n\n"
    "See `status.tsv`, `acceptance.json`, and per-step logs in this directory.\n"
)
PY

printf '\nacceptance_dir=%s\n' "$out_dir"
if [ "$failures" -ne 0 ]; then
  exit 1
fi
