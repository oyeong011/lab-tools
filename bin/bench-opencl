#!/usr/bin/env bash
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
SRC="$HOME/.config/lab/opencl-vector-add.c"
BUILD_DIR="$LAB_HOME/_benchmarks/opencl"
BIN="$BUILD_DIR/opencl-vector-add"
OUT="$BUILD_DIR/opencl-vector-add-$(date +%Y%m%d-%H%M%S).txt"

mkdir -p "$BUILD_DIR"

if [ ! -x "$BIN" ] || [ "$SRC" -nt "$BIN" ]; then
  gcc -O2 "$SRC" -lOpenCL -lm -o "$BIN"
  printf 'Build: compiled %s\n' "$BIN"
else
  printf 'Build: reused %s\n' "$BIN"
fi
"$BIN" | tee "$OUT"
printf '\nSaved: %s\n' "$OUT"
