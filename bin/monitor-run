#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage:
  monitor-run EXPERIMENT -- COMMAND [ARGS...]

Environment:
  LAB_MONITOR_INTERVAL=2  Seconds between monitor.csv samples
  LAB_TIMEOUT=10m         Max runtime
  LAB_MAX_TEMP_C=85       Thermal precheck threshold

This is a readable alias for lab-safe-run. Output is stored under:
  ~/lab/<experiment>/runs/<timestamp>/
EOF
}

if [ $# -lt 3 ] || [ "${2:-}" != "--" ]; then
  usage >&2
  exit 2
fi

exec "$SCRIPT_DIR/lab-safe-run" "$@"
