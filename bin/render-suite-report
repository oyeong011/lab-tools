#!/usr/bin/env python3
"""Render a Markdown report for a suite (header-aware, schema-tolerant)."""
import csv
import subprocess
import sys
from datetime import datetime
from pathlib import Path


HEADLINE_METRICS = [
    ("scalar_fma_mean_s", "Scalar s"),
    ("memory_walk_mean_s", "Memory s"),
    ("sha256_mean_s", "SHA s"),
    ("stream_triad_mb_s", "STREAM MB/s"),
    ("openblas_gflops", "OpenBLAS GF/s"),
    ("sysbench_events_s", "sysbench ev/s"),
    ("opencl_kernel_s", "OpenCL s"),
    ("opencl_bandwidth_gbs", "OpenCL GB/s"),
    ("gemm_gflops", "OCL-GEMM GF/s"),
    ("cuda_kernel_s", "CUDA s"),
    ("cuda_bandwidth_gbs", "CUDA GB/s"),
    ("cuda_gemm_gflops", "CUDA-GEMM GF/s"),
    ("duration_s", "Dur s"),
    ("pkg_energy_j", "Pkg J"),
    ("pkg_power_w", "Pkg W"),
    ("nvidia_energy_j", "GPU J"),
    ("nvidia_avg_power_w", "GPU W"),
]


def main():
    if len(sys.argv) != 2:
        print("Usage: render-suite-report SUITE_DIR", file=sys.stderr)
        return 2
    suite = Path(sys.argv[1]).resolve()
    if not suite.is_dir():
        print(f"Not a directory: {suite}", file=sys.stderr)
        return 2

    csv_path = suite / "summary.csv"
    if not csv_path.exists():
        subprocess.run(["summarize-suite", str(suite)], check=False, stdout=subprocess.DEVNULL)

    if not csv_path.exists():
        print(f"summary.csv missing: {csv_path}", file=sys.stderr)
        return 2

    with csv_path.open(newline="") as f:
        rows = list(csv.DictReader(f))

    stats_rows = []
    stats_path = suite / "stats.csv"
    if stats_path.exists():
        with stats_path.open(newline="") as f:
            stats_rows = list(csv.DictReader(f))

    report = suite / "report.md"
    with report.open("w") as f:
        f.write("# Suite Report\n\n")
        f.write(f"- Suite: `{suite}`\n")
        f.write(f"- Generated: `{datetime.now().isoformat(timespec='seconds')}`\n\n")

        f.write("## Results\n\n")
        headers = ["Workload", "Run", "Phase", "Status"] + [label for _, label in HEADLINE_METRICS] + ["Throttle"]
        f.write("| " + " | ".join(headers) + " |\n")
        f.write("| " + " | ".join("---" for _ in headers) + " |\n")
        for r in rows:
            cells = [
                r.get("workload", ""),
                r.get("run", ""),
                r.get("phase", ""),
                r.get("status", ""),
            ]
            for key, _ in HEADLINE_METRICS:
                cells.append(r.get(key, ""))
            cells.append(r.get("thermal_event_count", ""))
            f.write("| " + " | ".join(cells) + " |\n")

        f.write("\n## Run Directories\n\n")
        for r in rows:
            f.write(f"- {r.get('workload','')} run {r.get('run','')} ({r.get('phase','')}): `{r.get('run_dir','')}`\n")

        if stats_rows:
            f.write("\n## Statistics\n\n")
            cols = [
                ("workload", "Workload"),
                ("phase", "Phase"),
                ("metric", "Metric"),
                ("n", "N"),
                ("mean", "Mean"),
                ("median", "Median"),
                ("stddev", "SD"),
                ("cv_percent", "CV%"),
                ("ci95_half_width", "±1.96σ/√n"),
                ("bootstrap_ci_low", "BootCI lo"),
                ("bootstrap_ci_high", "BootCI hi"),
                ("mad", "MAD"),
                ("outliers_n", "Out"),
                ("quality", "Q"),
            ]
            f.write("| " + " | ".join(label for _, label in cols) + " |\n")
            f.write("| " + " | ".join("---" for _ in cols) + " |\n")
            for r in stats_rows:
                f.write("| " + " | ".join(r.get(key, "") for key, _ in cols) + " |\n")

        order_path = suite / "execution-order.csv"
        if order_path.exists():
            f.write("\n## Execution Order\n\n```\n")
            f.write(order_path.read_text())
            f.write("```\n")

    print(report)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
