#!/usr/bin/env bash
set -euo pipefail

suite_dir="${1:-}"
if [ -z "$suite_dir" ]; then
  printf 'Usage: summarize-suite SUITE_DIR\n' >&2
  exit 2
fi

if [ ! -d "$suite_dir" ]; then
  printf 'Suite directory not found: %s\n' "$suite_dir" >&2
  exit 2
fi

csv="$suite_dir/summary.csv"
printf 'workload,run,status,scalar_fma_mean_s,memory_walk_mean_s,sha256_mean_s,stream_triad_mb_s,openblas_gflops,sysbench_events_s,opencl_kernel_s,opencl_bandwidth_gbs,gemm_gflops,cuda_kernel_s,cuda_bandwidth_gbs,cuda_gemm_gflops,max_error,run_dir\n' > "$csv"

status_for() {
  if grep -q '^Run complete:' "$1"; then
    printf 'ok'
  elif grep -q '^Run failed' "$1"; then
    printf 'failed'
  else
    printf 'unknown'
  fi
}

run_dir_for() {
  sed -n 's/^Run complete: //p; s/^Run failed with status [0-9][0-9]*: //p' "$1" | tail -n 1
}

for log in "$suite_dir"/cpu-run-*.log; do
  [ -e "$log" ] || continue
  run="$(basename "$log" | sed -E 's/cpu-run-([0-9]+)\.log/\1/')"
  status="$(status_for "$log")"
  scalar="$(sed -n 's/^scalar_fma:.*mean=\([0-9.]*\)s.*/\1/p' "$log" | tail -n 1)"
  memory="$(sed -n 's/^memory_walk_32m:.*mean=\([0-9.]*\)s.*/\1/p' "$log" | tail -n 1)"
  sha="$(sed -n 's/^sha256_512m:.*mean=\([0-9.]*\)s.*/\1/p' "$log" | tail -n 1)"
  run_dir="$(run_dir_for "$log")"
  printf 'cpu,%s,%s,%s,%s,%s,,,,,,,,,,,%s\n' "$run" "$status" "$scalar" "$memory" "$sha" "$run_dir" >> "$csv"
done

for log in "$suite_dir"/standard-cpu-run-*.log; do
  [ -e "$log" ] || continue
  run="$(basename "$log" | sed -E 's/standard-cpu-run-([0-9]+)\.log/\1/')"
  status="$(status_for "$log")"
  stream="$(sed -n 's/^Triad bandwidth: \([0-9.]*\) MB\/s.*/\1/p' "$log" | tail -n 1)"
  openblas="$(sed -n 's/^OpenBLAS GFLOP\/s: \([0-9.]*\).*/\1/p' "$log" | tail -n 1)"
  sysbench="$(sed -n 's/^[[:space:]]*events per second:[[:space:]]*\([0-9.]*\).*/\1/p' "$log" | tail -n 1)"
  run_dir="$(run_dir_for "$log")"
  printf 'standard-cpu,%s,%s,,,,%s,%s,%s,,,,,,,,%s\n' "$run" "$status" "$stream" "$openblas" "$sysbench" "$run_dir" >> "$csv"
done

for log in "$suite_dir"/opencl-run-*.log; do
  [ -e "$log" ] || continue
  run="$(basename "$log" | sed -E 's/opencl-run-([0-9]+)\.log/\1/')"
  status="$(status_for "$log")"
  kernel="$(sed -n 's/^Kernel time: \([0-9.]*\) s.*/\1/p' "$log" | tail -n 1)"
  bandwidth="$(sed -n 's/^Device approx bandwidth: \([0-9.]*\) GB\/s.*/\1/p' "$log" | tail -n 1)"
  if [ -z "$bandwidth" ]; then
    bandwidth="$(sed -n 's/^Approx bandwidth: \([0-9.]*\) GB\/s.*/\1/p' "$log" | tail -n 1)"
  fi
  max_error="$(sed -n 's/^Max error: \([^ ]*\).*/\1/p' "$log" | tail -n 1)"
  run_dir="$(run_dir_for "$log")"
  printf 'opencl-vector,%s,%s,,,,,,,%s,%s,,,,,%s,%s\n' "$run" "$status" "$kernel" "$bandwidth" "$max_error" "$run_dir" >> "$csv"
done

for log in "$suite_dir"/opencl-gemm-run-*.log; do
  [ -e "$log" ] || continue
  run="$(basename "$log" | sed -E 's/opencl-gemm-run-([0-9]+)\.log/\1/')"
  status="$(status_for "$log")"
  kernel="$(sed -n 's/^Kernel time: \([0-9.]*\) s.*/\1/p' "$log" | tail -n 1)"
  gflops="$(sed -n 's/^Device approx GFLOP\/s: \([0-9.]*\).*/\1/p' "$log" | tail -n 1)"
  if [ -z "$gflops" ]; then
    gflops="$(sed -n 's/^Approx GFLOP\/s: \([0-9.]*\).*/\1/p' "$log" | tail -n 1)"
  fi
  max_error="$(sed -n 's/^Sample max error: \([^ ]*\).*/\1/p' "$log" | tail -n 1)"
  run_dir="$(run_dir_for "$log")"
  printf 'opencl-gemm,%s,%s,,,,,,,%s,,%s,,,,%s,%s\n' "$run" "$status" "$kernel" "$gflops" "$max_error" "$run_dir" >> "$csv"
done

for log in "$suite_dir"/cuda-vector-run-*.log; do
  [ -e "$log" ] || continue
  run="$(basename "$log" | sed -E 's/cuda-vector-run-([0-9]+)\.log/\1/')"
  status="$(status_for "$log")"
  kernel="$(sed -n 's/^Kernel time: \([0-9.]*\) s.*/\1/p' "$log" | tail -n 1)"
  bandwidth="$(sed -n 's/^Device approx bandwidth: \([0-9.]*\) GB\/s.*/\1/p' "$log" | tail -n 1)"
  max_error="$(sed -n 's/^Max error: \([^ ]*\).*/\1/p' "$log" | tail -n 1)"
  run_dir="$(run_dir_for "$log")"
  printf 'cuda-vector,%s,%s,,,,,,,,,,%s,%s,,%s,%s\n' "$run" "$status" "$kernel" "$bandwidth" "$max_error" "$run_dir" >> "$csv"
done

for log in "$suite_dir"/cuda-gemm-run-*.log; do
  [ -e "$log" ] || continue
  run="$(basename "$log" | sed -E 's/cuda-gemm-run-([0-9]+)\.log/\1/')"
  status="$(status_for "$log")"
  kernel="$(sed -n 's/^Kernel time: \([0-9.]*\) s.*/\1/p' "$log" | tail -n 1)"
  gflops="$(sed -n 's/^Device approx GFLOP\/s: \([0-9.]*\).*/\1/p' "$log" | tail -n 1)"
  max_error="$(sed -n 's/^Sample max error: \([^ ]*\).*/\1/p' "$log" | tail -n 1)"
  run_dir="$(run_dir_for "$log")"
  printf 'cuda-gemm,%s,%s,,,,,,,,,,%s,,%s,%s,%s\n' "$run" "$status" "$kernel" "$gflops" "$max_error" "$run_dir" >> "$csv"
done

for log in "$suite_dir"/cuda-uvm-run-*.log; do
  [ -e "$log" ] || continue
  run="$(basename "$log" | sed -E 's/cuda-uvm-run-([0-9]+)\.log/\1/')"
  status="$(status_for "$log")"
  kernel="$(sed -n 's/^Kernel time: \([0-9.]*\) s.*/\1/p' "$log" | tail -n 1)"
  bandwidth="$(sed -n 's/^Device approx bandwidth: \([0-9.]*\) GB\/s.*/\1/p' "$log" | tail -n 1)"
  max_error="$(sed -n 's/^Max error: \([^ ]*\).*/\1/p' "$log" | tail -n 1)"
  run_dir="$(run_dir_for "$log")"
  printf 'cuda-uvm,%s,%s,,,,,,,,,,%s,%s,,%s,%s\n' "$run" "$status" "$kernel" "$bandwidth" "$max_error" "$run_dir" >> "$csv"
done

python3 - "$csv" "$suite_dir" <<'PY'
import csv, json, os, sys
csv_path, suite_dir = sys.argv[1], sys.argv[2]

with open(csv_path, newline="") as f:
    reader = csv.DictReader(f)
    rows = list(reader)
    base_fieldnames = list(reader.fieldnames or [])

extra = ["duration_s", "pkg_energy_j", "core_energy_j", "uncore_energy_j", "dram_energy_j", "pkg_power_w", "nvidia_energy_j", "nvidia_avg_power_w", "gpu_max_temp_c", "phase", "thermal_event_count"]
fieldnames = list(rows[0].keys()) if rows else base_fieldnames
for col in extra:
    if col not in fieldnames:
        fieldnames.append(col)

order_path = os.path.join(suite_dir, "execution-order.csv")
order_lookup = {}
first_seen_order = {}
if os.path.exists(order_path):
    with open(order_path, newline="") as f:
        for r in csv.DictReader(f):
            try:
                o = int(r["order"])
            except (KeyError, ValueError):
                continue
            wl, rep = r.get("workload", ""), r.get("repeat", "")
            order_lookup[(wl, rep)] = o
            if wl not in first_seen_order or o < first_seen_order[wl]:
                first_seen_order[wl] = o

def phase_for(workload, run):
    if workload == "opencl-vector":
        wl_key = "opencl"
    elif workload == "standard-cpu":
        wl_key = "standard-cpu"
    else:
        wl_key = workload
    o = order_lookup.get((wl_key, run))
    if o is None:
        return "all"
    return "cold" if o == first_seen_order.get(wl_key) else "steady"

for row in rows:
    rd = (row.get("run_dir") or "").strip()
    row["phase"] = phase_for(row.get("workload", ""), row.get("run", ""))
    if not rd:
        continue
    rj = os.path.join(rd, "result.json")
    if not os.path.exists(rj):
        continue
    try:
        data = json.load(open(rj))
    except Exception:
        continue
    if data.get("duration_s") is not None:
        row["duration_s"] = data["duration_s"]
    energy = data.get("energy_j") or {}
    for k in ("pkg_energy_j", "core_energy_j", "uncore_energy_j", "dram_energy_j", "nvidia_energy_j"):
        if k in energy:
            row[k] = energy[k]
    power = data.get("avg_power_w") or {}
    if "pkg_power_w" in power:
        row["pkg_power_w"] = power["pkg_power_w"]
    if "nvidia_avg_power_w" in power:
        row["nvidia_avg_power_w"] = power["nvidia_avg_power_w"]
    if data.get("gpu_max_temp_c") is not None:
        row["gpu_max_temp_c"] = data["gpu_max_temp_c"]
    if data.get("thermal_event_count") is not None:
        row["thermal_event_count"] = data["thermal_event_count"]

with open(csv_path, "w", newline="") as f:
    w = csv.DictWriter(f, fieldnames=fieldnames)
    w.writeheader()
    w.writerows(rows)
PY

printf '%s\n' "$csv"
