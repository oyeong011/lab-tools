#!/usr/bin/env bash
set -euo pipefail

section() {
  printf '\n== %s ==\n' "$1"
}

section "PCI NVIDIA devices"
if lspci -nn | grep -Ei 'nvidia|3d controller|vga compatible controller'; then
  :
else
  printf 'No NVIDIA PCI GPU detected.\n'
fi

section "NVIDIA device nodes"
ls -la /dev/nvidia* 2>/dev/null || printf 'No /dev/nvidia* device nodes found.\n'

section "NVIDIA tools"
if command -v nvidia-smi >/dev/null 2>&1; then
  nvidia-smi
else
  printf 'nvidia-smi not installed or NVIDIA driver not active.\n'
fi

section "CUDA compiler"
if command -v nvcc >/dev/null 2>&1; then
  nvcc --version
else
  printf 'nvcc not installed.\n'
fi

section "Future install note"
printf '%s\n' 'When NVIDIA hardware is installed, prefer Ubuntu Additional Drivers first.'
printf '%s\n' 'After driver installation, verify with: nvidia-check && ai-accel-check'
