#!/usr/bin/env bash
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
TIMEOUT="${LAB_TIMEOUT:-10m}"
CPUSET="${LAB_CPUSET:-}"
MAX_TEMP_C="${LAB_MAX_TEMP_C:-85}"
MONITOR_INTERVAL="${LAB_MONITOR_INTERVAL:-2}"
PATH="$HOME/bin:$PATH"

RAPL_PKG_PATH=""
RAPL_CORE_PATH=""
RAPL_UNCORE_PATH=""
RAPL_DRAM_PATH=""
for _d in /sys/class/powercap/intel-rapl:* /sys/class/powercap/intel-rapl:*:*; do
  [ -d "$_d" ] || continue
  _n="$(cat "$_d/name" 2>/dev/null || true)"
  _e="$_d/energy_uj"
  [ -r "$_e" ] || continue
  case "$_n" in
    package-0) RAPL_PKG_PATH="$_e" ;;
    core)      RAPL_CORE_PATH="$_e" ;;
    uncore)    RAPL_UNCORE_PATH="$_e" ;;
    dram)      RAPL_DRAM_PATH="$_e" ;;
  esac
done
unset _d _n _e

read_rapl_path() {
  local path="$1"
  if [ -n "$path" ] && [ -r "$path" ]; then
    cat "$path" 2>/dev/null || true
  fi
}

NVIDIA_SMI=""
if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi -L >/dev/null 2>&1; then
  NVIDIA_SMI="nvidia-smi"
fi

read_nvidia_sample() {
  if [ -z "$NVIDIA_SMI" ]; then
    printf ',,,'
    return
  fi
  $NVIDIA_SMI --query-gpu=temperature.gpu,power.draw,utilization.gpu,memory.used \
    --format=csv,noheader,nounits -i 0 2>/dev/null \
    | head -n 1 \
    | awk -F', ' '{ printf "%s,%s,%s,%s", $1, $2, $3, $4 }' \
    || printf ',,,'
}

usage() {
  cat <<'EOF'
Usage:
  lab-safe-run EXPERIMENT -- COMMAND [ARGS...]

Environment:
  LAB_TIMEOUT=10m       Max runtime before timeout stops the command
  LAB_CPUSET=0-3        Optional CPU affinity passed to taskset
  LAB_MAX_TEMP_C=85     Refuse to start if current temperature is too high
  LAB_MONITOR_INTERVAL=2  Seconds between monitor.csv samples

Example:
  lab-safe-run cpu-ai-kernel-baseline -- bench-opencl
EOF
}

if [ $# -lt 3 ] || [ "$2" != "--" ]; then
  usage >&2
  exit 2
fi

experiment="$1"
shift 2

case "$experiment" in
  *[!A-Za-z0-9._-]*|'')
    printf 'Invalid experiment name: %s\n' "$experiment" >&2
    exit 2
    ;;
esac

workdir="$LAB_HOME/$experiment"
run_id="$(date +%Y%m%d-%H%M%S-%N)-$$"
run_dir="$workdir/runs/$run_id"

if [ ! -d "$workdir" ]; then
  printf 'Experiment does not exist: %s\n' "$workdir" >&2
  printf 'Create it first with: lab new %s\n' "$experiment" >&2
  exit 2
fi

mkdir -p "$run_dir"
started_at="$(date --iso-8601=seconds)"

{
  printf 'run_id=%s\n' "$run_id"
  printf 'experiment=%s\n' "$experiment"
  printf 'workdir=%s\n' "$workdir"
	  printf 'timeout=%s\n' "$TIMEOUT"
	  printf 'cpuset=%s\n' "${CPUSET:-all}"
	  printf 'max_temp_c=%s\n' "$MAX_TEMP_C"
	  printf 'monitor_interval=%s\n' "$MONITOR_INTERVAL"
	  printf 'command='
  printf '%q ' "$@"
  printf '\n'
} > "$run_dir/meta.txt"
lab-manifest "$run_dir" "$experiment" "$workdir" -- "$@" >/dev/null 2>&1 || true

sensor-snapshot > "$run_dir/sensors-before.txt" 2>&1 || true
if ! thermal-check "$MAX_TEMP_C" > "$run_dir/thermal-before.txt" 2>&1; then
  printf 'Thermal guard refused to start. See: %s\n' "$run_dir/thermal-before.txt" >&2
  printf '99\n' > "$run_dir/status.txt"
  printf 'thermal_precheck\n' > "$run_dir/failure-reason.txt"
  python3 - "$run_dir" "$started_at" "$(date --iso-8601=seconds)" 99 thermal_precheck <<'PY'
import json, sys
run_dir, started, ended, status, reason = sys.argv[1:]
open(f"{run_dir}/result.json", "w").write(json.dumps({
  "started_at": started, "ended_at": ended, "exit_code": int(status),
  "status": "failed", "failure_reason": reason
}, indent=2) + "\n")
PY
  exit 99
fi

cmd=(timeout --preserve-status "$TIMEOUT" nice -n 10 ionice -c 2 -n 7)
if [ -n "$CPUSET" ]; then
  cmd+=(taskset -c "$CPUSET")
fi
cmd+=("$@")

sample_monitor() {
  local timestamp max_temp cpu_scaling load1 mem_available_kib pkg core uncore dram nv
  timestamp="$(date --iso-8601=seconds)"
  max_temp="$(thermal-check 999 2>/dev/null | sed -n 's/^max_temp_c=\([^ ]*\).*/\1/p' || true)"
  cpu_scaling="$(lscpu 2>/dev/null | sed -n 's/^CPU(s) scaling MHz:[[:space:]]*//p' | head -n 1)"
  load1="$(awk '{print $1}' /proc/loadavg 2>/dev/null || true)"
  mem_available_kib="$(awk '/MemAvailable:/ {print $2}' /proc/meminfo 2>/dev/null || true)"
  pkg="$(read_rapl_path "$RAPL_PKG_PATH")"
  core="$(read_rapl_path "$RAPL_CORE_PATH")"
  uncore="$(read_rapl_path "$RAPL_UNCORE_PATH")"
  dram="$(read_rapl_path "$RAPL_DRAM_PATH")"
  nv="$(read_nvidia_sample)"
  printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' "$timestamp" "${max_temp:-}" "${cpu_scaling:-}" "${load1:-}" "${mem_available_kib:-}" "${pkg:-}" "${core:-}" "${uncore:-}" "${dram:-}" "$nv"
}

monitor_loop() {
  local pid="$1"
  local temp
  printf 'timestamp,max_temp_c,cpu_scaling_mhz_percent,load1,mem_available_kib,pkg_energy_uj,core_energy_uj,uncore_energy_uj,dram_energy_uj,gpu_temp_c,gpu_power_w,gpu_util_percent,gpu_mem_used_mib\n' > "$run_dir/monitor.csv"
  while kill -0 "$pid" 2>/dev/null; do
    sample_monitor >> "$run_dir/monitor.csv"
    temp="$(tail -n 1 "$run_dir/monitor.csv" | awk -F, '{print $2}')"
    if [ -n "$temp" ] && ! awk -v temp="$temp" -v max="$MAX_TEMP_C" 'BEGIN { exit (temp >= max ? 0 : 1) }'; then
      :
    elif [ -n "$temp" ]; then
      printf 'thermal_runtime\n' > "$run_dir/failure-reason.txt"
      kill -TERM "$pid" 2>/dev/null || true
      sleep 2
      kill -KILL "$pid" 2>/dev/null || true
      break
    fi
    sleep "$MONITOR_INTERVAL"
  done
  sample_monitor >> "$run_dir/monitor.csv"
}

status=0
(
  cd "$workdir"
  "${cmd[@]}"
) > >(tee "$run_dir/stdout.log") 2> >(tee "$run_dir/stderr.log" >&2) &
cmd_pid=$!
monitor_loop "$cmd_pid" &
monitor_pid=$!
wait "$cmd_pid" || status=$?
wait "$monitor_pid" 2>/dev/null || true
if [ -f "$run_dir/failure-reason.txt" ] && grep -q '^thermal_runtime$' "$run_dir/failure-reason.txt"; then
  status=98
fi

sensor-snapshot > "$run_dir/sensors-after.txt" 2>&1 || true
thermal-check "$MAX_TEMP_C" > "$run_dir/thermal-after.txt" 2>&1 || true
printf '%s\n' "$status" > "$run_dir/status.txt"
ended_at="$(date --iso-8601=seconds)"
reason="none"
if [ "$status" -eq 124 ]; then
  reason="timeout"
elif [ "$status" -eq 98 ]; then
  reason="thermal_runtime"
elif [ "$status" -ne 0 ]; then
  reason="command_failed"
fi
if [ -f "$run_dir/failure-reason.txt" ]; then
  reason="$(cat "$run_dir/failure-reason.txt")"
else
  printf '%s\n' "$reason" > "$run_dir/failure-reason.txt"
fi
pinned="unknown"
if command -v lab-pin-system >/dev/null 2>&1; then
  if lab-pin-system check 2>/dev/null; then pinned="yes"; else pinned="no"; fi
fi

python3 - "$run_dir" "$started_at" "$ended_at" "$status" "$reason" "$pinned" <<'PY'
import csv, json, os, sys

run_dir, started, ended, status, reason, pinned = sys.argv[1:]
code = int(status)

energy = {}
throttled = False
monitor_path = os.path.join(run_dir, "monitor.csv")
if os.path.exists(monitor_path):
    try:
        with open(monitor_path) as f:
            rows = list(csv.DictReader(f))
    except Exception:
        rows = []
    for col, key in [
        ("pkg_energy_uj", "pkg_energy_j"),
        ("core_energy_uj", "core_energy_j"),
        ("uncore_energy_uj", "uncore_energy_j"),
        ("dram_energy_uj", "dram_energy_j"),
    ]:
        vals = []
        for r in rows:
            v = (r.get(col) or "").strip()
            if v.isdigit():
                vals.append(int(v))
        if len(vals) < 2:
            continue
        delta_uj = vals[-1] - vals[0]
        if delta_uj < 0:
            continue
        energy[key] = delta_uj / 1e6
    throttle_threshold = 90.0
    thermal_event_count = 0
    for r in rows:
        t = (r.get("max_temp_c") or "").strip()
        try:
            if t and float(t) >= throttle_threshold:
                throttled = True
                thermal_event_count += 1
        except ValueError:
            pass

    nvidia_energy_j = None
    nvidia_avg_power_w = None
    gpu_max_temp_c = None
    if any((r.get("gpu_power_w") or "").strip() for r in rows):
        from datetime import datetime as _dt
        ts_w = []
        for r in rows:
            ts = (r.get("timestamp") or "").strip()
            pw = (r.get("gpu_power_w") or "").strip()
            try:
                t_obj = _dt.fromisoformat(ts) if ts else None
                pw_v = float(pw) if pw else None
            except (TypeError, ValueError):
                continue
            if t_obj is not None and pw_v is not None:
                ts_w.append((t_obj, pw_v))
        if len(ts_w) >= 2:
            integral = 0.0
            for i in range(1, len(ts_w)):
                dt = (ts_w[i][0] - ts_w[i - 1][0]).total_seconds()
                integral += 0.5 * (ts_w[i][1] + ts_w[i - 1][1]) * dt
            nvidia_energy_j = integral
            elapsed = (ts_w[-1][0] - ts_w[0][0]).total_seconds()
            if elapsed > 0:
                nvidia_avg_power_w = integral / elapsed
        for r in rows:
            t = (r.get("gpu_temp_c") or "").strip()
            try:
                if t:
                    v = float(t)
                    if gpu_max_temp_c is None or v > gpu_max_temp_c:
                        gpu_max_temp_c = v
            except ValueError:
                pass

duration_s = None
try:
    from datetime import datetime
    duration_s = (datetime.fromisoformat(ended) - datetime.fromisoformat(started)).total_seconds()
except Exception:
    pass

power = {}
if duration_s and duration_s > 0:
    for key, value in energy.items():
        power[key.replace("_energy_j", "_power_w")] = value / duration_s

if nvidia_energy_j is not None:
    energy["nvidia_energy_j"] = nvidia_energy_j
if nvidia_avg_power_w is not None:
    power["nvidia_avg_power_w"] = nvidia_avg_power_w

result = {
    "started_at": started,
    "ended_at": ended,
    "duration_s": duration_s,
    "exit_code": code,
    "status": "ok" if code == 0 else "failed",
    "failure_reason": reason,
    "timeout": code == 124,
    "thermal_runtime_abort": code == 98,
    "thermal_event_observed": throttled,
    "thermal_event_count": thermal_event_count,
    "gpu_max_temp_c": gpu_max_temp_c,
    "system_pinned": pinned,
    "energy_j": energy,
    "avg_power_w": power,
}
open(f"{run_dir}/result.json", "w").write(json.dumps(result, indent=2, sort_keys=True) + "\n")
PY

if [ "$status" -eq 0 ]; then
  printf 'Run complete: %s\n' "$run_dir"
else
  printf 'Run failed with status %s: %s\n' "$status" "$run_dir" >&2
fi

exit "$status"
