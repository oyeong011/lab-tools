#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PATH="$SCRIPT_DIR:$HOME/bin:$PATH"

ok=0
warn=0

check_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    printf 'ok   command %-22s %s\n' "$1" "$(command -v "$1")"
  else
    printf 'warn command %-22s missing\n' "$1"
    warn=$((warn + 1))
  fi
}

info_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    printf 'ok   command %-22s %s\n' "$1" "$(command -v "$1")"
  else
    printf 'info command %-22s missing\n' "$1"
  fi
}

check_file() {
  if [ -e "$1" ]; then
    printf 'ok   file    %s\n' "$1"
  else
    printf 'warn file    %s missing\n' "$1"
    warn=$((warn + 1))
  fi
}

PROFILE="$(lab-profile 2>/dev/null || printf cpu)"

printf '== Lab Doctor ==\n'
printf 'time=%s\n' "$(date -Iseconds)"
printf 'host=%s\n' "$(hostname)"
printf 'profile=%s\n\n' "$PROFILE"

printf '== Framework commands (all profiles) ==\n'
for cmd in \
  lab-safe-run lab-pin-system lab-profile lab-tools-install lab-tools-sync \
  lab-apple-smoke lab-pipeline lab-rtx-smoke lab-uvm-profile lab-validate \
  lab-doctor lab-host-acceptance lab-manifest lab-handoff lab-index lab-archive lab-backup lab-plot lab-clean \
  bench-suite bench-suite-config summarize-suite suite-stats suite-compare \
  render-suite-report render-suite-html render-method-section render-repro-checklist \
  hw-report thermal-check sensor-snapshot monitor-run \
  lab-container-build lab-container-run \
  ; do
  check_cmd "$cmd"
done

printf '\n== CPU/OpenCL benchmark commands ==\n'
for cmd in bench-cpu bench-standard-cpu bench-stream bench-openblas bench-sysbench bench-opencl bench-opencl-gemm ai-accel-check; do
  check_cmd "$cmd"
done

printf '\n== System tools ==\n'
for cmd in clinfo gcc python3 sysbench git rsync tar sha256sum podman buildah; do
  check_cmd "$cmd"
done

if python3 -c 'import matplotlib' >/dev/null 2>&1; then
  printf 'ok   python  matplotlib\n'
else
  printf 'warn python  matplotlib missing\n'
  warn=$((warn + 1))
fi
if python3 -c 'import yaml' >/dev/null 2>&1; then
  printf 'ok   python  yaml\n'
else
  printf 'warn python  yaml missing (needed for *.yaml suite configs and lab-pipeline)\n'
  warn=$((warn + 1))
fi
if python3 -c 'import scipy' >/dev/null 2>&1; then
  printf 'ok   python  scipy\n'
else
  printf 'warn python  scipy missing (suite-compare will mark p-values scipy_unavailable)\n'
  warn=$((warn + 1))
fi

printf '\n== CUDA toolchain ==\n'
case "$PROFILE" in
  cuda)
    for cmd in nvidia-smi nvcc nsys nvml-check bench-cuda-vector-add bench-cuda-gemm bench-cuda-uvm-access bench-cuda-gemv bench-cuda-spmv bench-cuda-gcn lab-rtx-smoke lab-uvm-profile; do
      check_cmd "$cmd"
    done
    ;;
  *)
    for cmd in nvidia-smi nvcc nsys nvml-check bench-cuda-vector-add bench-cuda-gemm bench-cuda-uvm-access bench-cuda-gemv bench-cuda-spmv bench-cuda-gcn lab-rtx-smoke lab-uvm-profile; do
      info_cmd "$cmd"
    done
    printf 'note     profile=%s — CUDA tools optional on this host\n' "$PROFILE"
    ;;
esac

printf '\n== Required files (CPU profile) ==\n'
check_file "$HOME/.config/lab/opencl-vector-add.c"
check_file "$HOME/.config/lab/opencl-gemm.c"
check_file "$HOME/.config/lab/stream-triad.c"
check_file "$HOME/.config/lab/openblas-gemm.c"
check_file "$HOME/.config/lab/suites/quick.env"
check_file "$HOME/.config/lab/suites/baseline.env"
check_file "$HOME/.config/lab/containers/Containerfile.cpu"

if [ "$PROFILE" = cuda ]; then
  printf '\n== Required files (CUDA profile) ==\n'
  check_file "$HOME/.config/lab/cuda-vector-add.cu"
  check_file "$HOME/.config/lab/cuda-gemm.cu"
  check_file "$HOME/.config/lab/cuda-uvm-access.cu"
  check_file "$HOME/.config/lab/cuda-memory-kernels.cu"
  check_file "$HOME/.config/lab/containers/Containerfile.cuda"
fi

if [ "$(uname -s)" = Darwin ]; then
  printf '\n== Apple profile files ==\n'
  check_cmd bench-apple-metal
  check_cmd bench-apple-mps
  check_file "$HOME/.config/lab/apple-metal-vector.swift"
fi

printf '\n== Container images ==\n'
if podman image exists localhost/lab-cpu:24.04 2>/dev/null; then
  printf 'ok   image   localhost/lab-cpu:24.04\n'
else
  printf 'info image   localhost/lab-cpu:24.04 missing; build with: lab-container-build cpu\n'
fi
if [ "$PROFILE" = cuda ]; then
  if podman image exists localhost/lab-cuda:24.04 2>/dev/null; then
    printf 'ok   image   localhost/lab-cuda:24.04\n'
  else
    printf 'warn image   localhost/lab-cuda:24.04 missing; build with: lab-container-build cuda\n'
    warn=$((warn + 1))
  fi
fi

printf '\n== Temperature ==\n'
thermal-check || { printf 'warn thermal-check failed\n'; warn=$((warn + 1)); }

printf '\n== OpenCL devices ==\n'
clinfo_list="$(clinfo -l 2>/dev/null || true)"
if printf '%s\n' "$clinfo_list" | grep -q 'Device #'; then
  printf '%s\n' "$clinfo_list"
else
  printf 'warn no OpenCL device detected\n'
  warn=$((warn + 1))
fi

if [ "$PROFILE" = cuda ]; then
  printf '\n== NVIDIA devices ==\n'
  if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi -L 2>/dev/null; then
    :
  else
    printf 'warn nvidia-smi -L returned no devices on cuda profile\n'
    warn=$((warn + 1))
  fi
fi

printf '\n== Summary ==\n'
if [ "$warn" -eq 0 ]; then
  printf 'status=ok profile=%s warnings=0\n' "$PROFILE"
else
  printf 'status=warn profile=%s warnings=%s\n' "$PROFILE" "$warn"
fi

exit 0
