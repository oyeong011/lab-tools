#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PATH="$SCRIPT_DIR:$HOME/bin:$PATH"

DRY_RUN=0
CONFIG_NAME="quick"

usage() {
  cat <<'EOF'
Usage:
  bench-suite-config [--dry-run] [CONFIG]

CONFIG may be a path or a config name under ~/.config/lab/suites.
--dry-run parses the config and prints the resolved environment without
creating an experiment or running benchmarks.
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help|help) usage; exit 0 ;;
    *)
      CONFIG_NAME="$1"
      shift
      ;;
  esac
done

CONFIG_PATH="$CONFIG_NAME"
if [ ! -f "$CONFIG_PATH" ]; then
  if [ -f "$HOME/.config/lab/suites/${CONFIG_NAME%.yaml}.yaml" ]; then
    CONFIG_PATH="$HOME/.config/lab/suites/${CONFIG_NAME%.yaml}.yaml"
  else
    CONFIG_PATH="$HOME/.config/lab/suites/${CONFIG_NAME%.env}.env"
  fi
fi

if [ ! -f "$CONFIG_PATH" ]; then
  printf 'Suite config not found: %s\n' "$CONFIG_NAME" >&2
  printf 'Available configs:\n' >&2
  if [ -d "$HOME/.config/lab/suites" ]; then
    find "$HOME/.config/lab/suites" -maxdepth 1 -type f \( -name '*.env' -o -name '*.yaml' \) \
      | while IFS= read -r file; do printf '  %s\n' "$(basename "$file")"; done \
      | sort >&2
  fi
  exit 2
fi

case "$CONFIG_PATH" in
  "$HOME"/.config/lab/suites/*.env|"$HOME"/.config/lab/suites/*.yaml|/*/*.env|/*/*.yaml|./*.env|./*.yaml|*.env|*.yaml) ;;
  *)
    printf 'Refusing suspicious config path: %s\n' "$CONFIG_PATH" >&2
    exit 2
    ;;
esac

case "$CONFIG_PATH" in
  *.yaml)
    eval "$(python3 - "$CONFIG_PATH" <<'PY'
import shlex
import sys
import yaml

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as f:
    data = yaml.safe_load(f) or {}

env = {}
if "experiment" in data:
    env["EXPERIMENT"] = str(data["experiment"])
if "warmups" in data:
    env["LAB_WARMUPS"] = str(data["warmups"])
if "repeats" in data:
    env["LAB_REPEATS"] = str(data["repeats"])
for key, value in (data.get("env") or {}).items():
    env[str(key)] = str(value)

allowed = {
    "EXPERIMENT",
    "LAB_WARMUPS",
    "LAB_REPEATS",
    "LAB_MONITOR_INTERVAL",
    "LAB_MAX_TEMP_C",
    "LAB_STREAM_ELEMENTS",
    "LAB_STREAM_REPEATS",
    "LAB_OPENBLAS_SIZE",
    "LAB_OPENBLAS_REPEATS",
    "LAB_SYSBENCH_THREADS",
    "LAB_SYSBENCH_TIME",
    "LAB_GEMM_SIZE",
    "LAB_INCLUDE_CUDA",
    "LAB_INCLUDE_UVM",
    "LAB_WORKLOADS",
    "LAB_UVM_MB",
    "LAB_UVM_PATTERN",
    "LAB_UVM_PASSES",
    "LAB_GEMV_SIZE",
    "LAB_SPMV_ROWS",
    "LAB_SPMV_NNZ_PER_ROW",
    "LAB_GCN_ROWS",
    "LAB_GCN_DEGREE",
    "LAB_GCN_FEATURE_DIM",
    "LAB_APPLE_ELEMENTS",
    "OPENBLAS_NUM_THREADS",
    "OMP_NUM_THREADS",
    "LAB_CPUSET",
    "LAB_TIMEOUT",
    "LAB_SHUFFLE",
    "LAB_SHUFFLE_SEED",
}

for key in sorted(env):
    if key not in allowed:
        raise SystemExit(f"unsupported suite yaml key/env: {key}")
    print(f"export {key}={shlex.quote(env[key])}")
PY
)"
    ;;
  *.env)
    set -a
    # shellcheck disable=SC1090
    . "$CONFIG_PATH"
    set +a
    ;;
esac

EXPERIMENT="${EXPERIMENT:-cpu-ai-kernel-baseline}"
REPEATS="${LAB_REPEATS:-3}"

printf 'Using suite config: %s\n' "$CONFIG_PATH"
printf 'Experiment: %s\n' "$EXPERIMENT"
printf 'Warmups: %s\n' "${LAB_WARMUPS:-0}"
printf 'Repeats: %s\n' "$REPEATS"
if [ "$DRY_RUN" -eq 1 ]; then
  printf 'Dry-run: yes\n'
  printf 'Resolved environment:\n'
  env | grep -E '^(EXPERIMENT|LAB_[A-Z0-9_]*|OPENBLAS_NUM_THREADS|OMP_NUM_THREADS)=' | sort | sed 's/^/  /'
  exit 0
fi

bench-suite "$EXPERIMENT" "$REPEATS"
