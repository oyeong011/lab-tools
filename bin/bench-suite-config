#!/usr/bin/env bash
set -euo pipefail
PATH="$HOME/bin:$PATH"

CONFIG_NAME="${1:-quick}"
CONFIG_PATH="$CONFIG_NAME"
if [ ! -f "$CONFIG_PATH" ]; then
  CONFIG_PATH="$HOME/.config/lab/suites/${CONFIG_NAME%.env}.env"
fi

if [ ! -f "$CONFIG_PATH" ]; then
  printf 'Suite config not found: %s\n' "$CONFIG_NAME" >&2
  printf 'Available configs:\n' >&2
  find "$HOME/.config/lab/suites" -maxdepth 1 -type f -name '*.env' -printf '  %f\n' | sort >&2
  exit 2
fi

case "$CONFIG_PATH" in
  "$HOME"/.config/lab/suites/*.env|/*/*.env|./*.env|*.env) ;;
  *)
    printf 'Refusing suspicious config path: %s\n' "$CONFIG_PATH" >&2
    exit 2
    ;;
esac

set -a
# shellcheck disable=SC1090
. "$CONFIG_PATH"
set +a

EXPERIMENT="${EXPERIMENT:-cpu-ai-kernel-baseline}"
REPEATS="${LAB_REPEATS:-3}"

printf 'Using suite config: %s\n' "$CONFIG_PATH"
printf 'Experiment: %s\n' "$EXPERIMENT"
printf 'Warmups: %s\n' "${LAB_WARMUPS:-0}"
printf 'Repeats: %s\n' "$REPEATS"

bench-suite "$EXPERIMENT" "$REPEATS"
