#!/usr/bin/env python3
"""Check a directory of acceptance bundles against the required lab host matrix."""
import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


def default_config_path():
    repo_config = Path(__file__).resolve().parent.parent / "config" / "acceptance" / "required-hosts.json"
    if repo_config.exists():
        return repo_config
    installed = Path.home() / ".config" / "lab" / "acceptance" / "required-hosts.json"
    return installed


def bundle_tool_path():
    local = Path(__file__).resolve().parent / "lab-acceptance-bundle"
    if local.exists():
        return str(local)
    found = shutil.which("lab-acceptance-bundle")
    if found:
        return found
    raise FileNotFoundError("lab-acceptance-bundle not found in checkout or PATH")


def load_config(path):
    config_path = Path(path).expanduser()
    data = json.loads(config_path.read_text(encoding="utf-8"))
    if data.get("schema_version") != 1:
        raise ValueError("acceptance matrix schema_version must be 1")
    targets = data.get("targets")
    if not isinstance(targets, list) or not targets:
        raise ValueError("acceptance matrix must contain a non-empty targets list")
    seen = set()
    for target in targets:
        if not isinstance(target, dict):
            raise ValueError("each target must be an object")
        name = target.get("name")
        profile = target.get("profile")
        if not name or not isinstance(name, str):
            raise ValueError("each target must have a string name")
        if name in seen:
            raise ValueError(f"duplicate target name: {name}")
        seen.add(name)
        if profile not in {"cpu", "cuda", "apple", "cluster"}:
            raise ValueError(f"target {name} has invalid profile: {profile!r}")
    return data


def discover_bundles(bundle_dirs, explicit_bundles, recursive):
    bundles = []
    for value in explicit_bundles:
        path = Path(value).expanduser()
        if path.exists():
            bundles.append(path.resolve())
    for value in bundle_dirs:
        root = Path(value).expanduser()
        if not root.exists() or not root.is_dir():
            continue
        patterns = ["*.tar.gz", "*.tgz"]
        for pattern in patterns:
            found = root.rglob(pattern) if recursive else root.glob(pattern)
            for path in found:
                if path.is_file():
                    bundles.append(path.resolve())
    unique = {}
    for bundle in bundles:
        unique[str(bundle)] = bundle
    return sorted(unique.values(), key=lambda p: (p.stat().st_mtime if p.exists() else 0, str(p)), reverse=True)


def target_command(tool, bundle, target):
    cmd = [tool, "--check-bundle", str(bundle), "--expect-profile", target["profile"]]
    if target.get("require_run"):
        cmd.append("--require-run")
    if target.get("require_uvm_profile"):
        cmd.append("--require-uvm-profile")
    if target.get("require_provenance"):
        cmd.append("--require-provenance")
    for value in target.get("require_gpu_name") or []:
        cmd.extend(["--require-gpu-name", str(value)])
    if target.get("min_gpu_memory_mib") is not None:
        cmd.extend(["--min-gpu-memory-mib", str(target["min_gpu_memory_mib"])])
    for value in target.get("require_compute_cap") or []:
        cmd.extend(["--require-compute-cap", str(value)])
    for value in target.get("require_cuda_sm") or []:
        cmd.extend(["--require-cuda-sm", str(value)])
    for value in target.get("require_opencl_device") or []:
        cmd.extend(["--require-opencl-device", str(value)])
    for value in target.get("require_apple_chip") or []:
        cmd.extend(["--require-apple-chip", str(value)])
    return cmd


def collect_command(target):
    cmd = ["lab-acceptance-collect", "--profile", target["profile"]]
    if target.get("require_run"):
        cmd.append("--run")
    if target.get("require_uvm_profile"):
        cmd.append("--uvm-profile")
    if target.get("require_provenance"):
        cmd.append("--require-provenance")
    for value in target.get("require_gpu_name") or []:
        cmd.extend(["--require-gpu-name", str(value)])
    if target.get("min_gpu_memory_mib") is not None:
        cmd.extend(["--min-gpu-memory-mib", str(target["min_gpu_memory_mib"])])
    for value in target.get("require_compute_cap") or []:
        cmd.extend(["--require-compute-cap", str(value)])
    for value in target.get("require_cuda_sm") or []:
        cmd.extend(["--require-cuda-sm", str(value)])
    for value in target.get("require_opencl_device") or []:
        cmd.extend(["--require-opencl-device", str(value)])
    for value in target.get("require_apple_chip") or []:
        cmd.extend(["--require-apple-chip", str(value)])
    return cmd


def remote_placeholder(target):
    name = target["name"]
    if target["profile"] == "cuda":
        gpu = (target.get("require_gpu_name") or ["gpu"])[0].lower().replace(" ", "")
        return f"user@{gpu}-host"
    if target["profile"] == "apple":
        chip = (target.get("require_apple_chip") or ["apple"])[0].lower().replace(" ", "")
        return f"user@{chip}-mac"
    return f"user@{name.replace('_', '-').replace('ubuntu-', '')}-host"


def remote_command(target):
    cmd = ["lab-remote-acceptance", remote_placeholder(target)]
    for word in collect_command(target)[1:]:
        cmd.append(word)
    return cmd


def shell_join(words):
    return " ".join(shlex_quote(str(word)) for word in words)


def shlex_quote(value):
    if not value:
        return "''"
    safe = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_@%+=:,./-"
    if all(ch in safe for ch in value):
        return value
    return "'" + value.replace("'", "'\"'\"'") + "'"


def check_target(tool, target, bundles, verbose):
    failures = []
    for bundle in bundles:
        cmd = target_command(tool, bundle, target)
        result = subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
        if result.returncode == 0:
            return {
                "name": target["name"],
                "status": "ok",
                "profile": target["profile"],
                "bundle": str(bundle),
                "command": cmd,
                "output": result.stdout if verbose else "",
            }
        failures.append({"bundle": str(bundle), "returncode": result.returncode, "output": result.stdout})
    return {
        "name": target["name"],
        "status": "missing",
        "profile": target["profile"],
        "bundle": "",
        "command": [],
        "failures": failures if verbose else [],
    }


def filter_targets(targets, names):
    if not names:
        return targets
    requested = set(names)
    selected = [target for target in targets if target["name"] in requested]
    missing = sorted(requested - {target["name"] for target in selected})
    if missing:
        raise ValueError("unknown target(s): " + ", ".join(missing))
    return selected


def print_table(results):
    widths = {
        "target": max([len("target")] + [len(item["name"]) for item in results]),
        "profile": max([len("profile")] + [len(item["profile"]) for item in results]),
        "status": max([len("status")] + [len(item["status"]) for item in results]),
    }
    print(f"{'target':<{widths['target']}}  {'profile':<{widths['profile']}}  {'status':<{widths['status']}}  bundle")
    print(f"{'-' * widths['target']}  {'-' * widths['profile']}  {'-' * widths['status']}  ------")
    for item in results:
        print(f"{item['name']:<{widths['target']}}  {item['profile']:<{widths['profile']}}  {item['status']:<{widths['status']}}  {item.get('bundle', '')}")


def print_next_commands(results, targets_by_name):
    missing = [item for item in results if item.get("status") != "ok"]
    if not missing:
        print("\nnext_commands=none")
        return
    print("\nNext commands for missing targets:")
    for item in missing:
        target = targets_by_name[item["name"]]
        print(f"\n# {item['name']} direct on target host")
        print(shell_join(collect_command(target)))
        print(f"# {item['name']} over SSH from this host")
        print(shell_join(remote_command(target)))


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", default=str(default_config_path()), help="Required host matrix JSON")
    parser.add_argument(
        "--bundle-dir",
        action="append",
        default=[],
        help="Directory containing acceptance bundles; may be repeated",
    )
    parser.add_argument("--bundle", action="append", default=[], help="Explicit acceptance bundle path; may be repeated")
    parser.add_argument("--target", action="append", default=[], help="Only check one target name; may be repeated")
    parser.add_argument("--recursive", action="store_true", help="Recursively search bundle directories")
    parser.add_argument("--dry-run", action="store_true", help="Print planned verification commands without running them")
    parser.add_argument("--next-commands", action="store_true", help="Print collection commands for missing targets")
    parser.add_argument("--json", action="store_true", help="Print machine-readable JSON")
    parser.add_argument("--verbose", action="store_true", help="Include verifier output for failed candidates")
    args = parser.parse_args()

    try:
        config = load_config(args.config)
        targets = filter_targets(config["targets"], args.target)
        bundle_dirs = args.bundle_dir or [os.environ.get("LAB_ACCEPTANCE_BUNDLE_DIR", str(Path.home() / "lab" / "_acceptance_bundles"))]
        bundles = discover_bundles(bundle_dirs, args.bundle, args.recursive)
        tool = bundle_tool_path()
    except Exception as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 2

    if args.dry_run:
        plan = []
        candidate = "<bundle.tar.gz>"
        for target in targets:
            cmd = target_command("lab-acceptance-bundle", candidate, target)
            plan.append({"name": target["name"], "profile": target["profile"], "command": cmd})
        if args.json:
            print(json.dumps({"schema_version": 1, "config": args.config, "bundle_dirs": bundle_dirs, "plan": plan}, indent=2))
        else:
            print(f"config={args.config}")
            print("bundle_dirs=" + ",".join(bundle_dirs))
            for item in plan:
                print(f"DRY {item['name']}: {shell_join(item['command'])}")
        return 0

    if not bundles:
        results = [
            {"name": target["name"], "status": "missing", "profile": target["profile"], "bundle": "", "command": []}
            for target in targets
        ]
    else:
        results = [check_target(tool, target, bundles, args.verbose) for target in targets]

    complete = all(item["status"] == "ok" for item in results)
    output = {
        "schema_version": 1,
        "config": str(Path(args.config).expanduser()),
        "bundle_dirs": bundle_dirs,
        "bundle_count": len(bundles),
        "complete": complete,
        "results": results,
    }
    if args.next_commands:
        targets_by_name = {target["name"]: target for target in targets}
        output["next_commands"] = {
            item["name"]: {
                "direct": collect_command(targets_by_name[item["name"]]),
                "remote": remote_command(targets_by_name[item["name"]]),
            }
            for item in results
            if item.get("status") != "ok"
        }
    if args.json:
        print(json.dumps(output, indent=2))
    else:
        print_table(results)
        print(f"\ncomplete={'yes' if complete else 'no'}")
        if not complete:
            print("missing_targets=" + ",".join(item["name"] for item in results if item["status"] != "ok"))
        if args.next_commands:
            print_next_commands(results, {target["name"]: target for target in targets})
    return 0 if complete else 1


if __name__ == "__main__":
    raise SystemExit(main())
