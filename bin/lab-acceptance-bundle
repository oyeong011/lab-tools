#!/usr/bin/env python3
"""Package or verify a lab-host-acceptance artifact transfer bundle."""
import argparse
import hashlib
import json
import shutil
import subprocess
import sys
import tarfile
import tempfile
from datetime import datetime
from pathlib import Path


def fail(message):
    print(f"error: {message}", file=sys.stderr)
    return 1


def sha256_file(path):
    h = hashlib.sha256()
    with Path(path).open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def resolve_artifact(path):
    artifact = Path(path).expanduser().resolve()
    if artifact.is_file() and artifact.name == "acceptance.json":
        artifact = artifact.parent
    json_path = artifact / "acceptance.json"
    if not json_path.exists():
        raise FileNotFoundError(f"acceptance.json not found: {json_path}")
    return artifact, json_path


def verifier_path():
    local = Path(__file__).resolve().parent / "lab-acceptance-verify"
    if local.exists():
        return str(local)
    found = shutil.which("lab-acceptance-verify")
    if found:
        return found
    raise FileNotFoundError("lab-acceptance-verify not found in checkout or PATH")


def run_verifier(args, artifact):
    cmd = [verifier_path(), str(artifact)]
    if args.expect_profile:
        cmd.extend(["--expect-profile", args.expect_profile])
    if args.require_run:
        cmd.append("--require-run")
    if args.require_uvm_profile:
        cmd.append("--require-uvm-profile")
    if args.require_provenance:
        cmd.append("--require-provenance")
    for gpu_name in args.require_gpu_name:
        cmd.extend(["--require-gpu-name", gpu_name])
    if args.min_gpu_memory_mib is not None:
        cmd.extend(["--min-gpu-memory-mib", str(args.min_gpu_memory_mib)])
    for compute_cap in args.require_compute_cap:
        cmd.extend(["--require-compute-cap", compute_cap])
    for cuda_sm in args.require_cuda_sm:
        cmd.extend(["--require-cuda-sm", cuda_sm])
    for opencl_device in args.require_opencl_device:
        cmd.extend(["--require-opencl-device", opencl_device])
    for apple_chip in args.require_apple_chip:
        cmd.extend(["--require-apple-chip", apple_chip])
    subprocess.run(cmd, check=True)
    return cmd


def output_path(out_arg, bundle_base):
    if out_arg:
        out = Path(out_arg).expanduser()
        if out.name.endswith(".tar.gz") or out.name.endswith(".tgz"):
            return out
        return out / f"{bundle_base}.tar.gz"
    return Path.home() / "lab" / "_acceptance_bundles" / f"{bundle_base}.tar.gz"


def file_records(root):
    records = []
    for path in sorted(root.rglob("*")):
        if not path.is_file():
            continue
        if path.name == "bundle-manifest.json":
            continue
        rel = path.relative_to(root).as_posix()
        records.append({"path": rel, "bytes": path.stat().st_size, "sha256": sha256_file(path)})
    return records


def safe_extract(tar, dest):
    base = dest.resolve()
    for member in tar.getmembers():
        if member.issym() or member.islnk():
            raise ValueError(f"refusing link member in bundle: {member.name}")
        target = (dest / member.name).resolve()
        if target != base and base not in target.parents:
            raise ValueError(f"refusing unsafe path in bundle: {member.name}")
    tar.extractall(dest)


def verify_sidecar_sha(bundle):
    sidecar = Path(str(bundle) + ".sha256")
    if not sidecar.exists():
        print(f"warning: sidecar sha256 not found: {sidecar}", file=sys.stderr)
        return False
    expected = sidecar.read_text(encoding="utf-8").split()[0]
    actual = sha256_file(bundle)
    if expected != actual:
        raise ValueError(f"bundle sha256 mismatch: expected {expected}, got {actual}")
    print(f"ok bundle sha256 {sidecar}")
    return True


def bundle_root(extract_dir):
    entries = [p for p in extract_dir.iterdir() if p.is_dir()]
    if len(entries) != 1:
        raise ValueError("bundle must contain exactly one top-level directory")
    return entries[0]


def verify_internal_hashes(root):
    sums = root / "SHA256SUMS"
    if not sums.exists():
        raise FileNotFoundError(f"SHA256SUMS not found in bundle root: {root}")
    checked = 0
    for line in sums.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        digest, rel = line.split(None, 1)
        rel = rel.strip()
        path = root / rel
        if not path.exists():
            raise FileNotFoundError(f"bundled file missing: {rel}")
        actual = sha256_file(path)
        if digest != actual:
            raise ValueError(f"bundled file sha256 mismatch for {rel}: expected {digest}, got {actual}")
        checked += 1
    print(f"ok internal SHA256SUMS files={checked}")
    return checked


def acceptance_from_bundle(root):
    manifest_path = root / "bundle-manifest.json"
    if not manifest_path.exists():
        raise FileNotFoundError(f"bundle-manifest.json not found: {manifest_path}")
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    if manifest.get("schema_version") != 1:
        raise ValueError("bundle-manifest schema_version must be 1")
    acceptance_root = root / "acceptance"
    artifacts = sorted(p for p in acceptance_root.iterdir() if (p / "acceptance.json").exists()) if acceptance_root.exists() else []
    if len(artifacts) != 1:
        raise ValueError(f"expected exactly one bundled acceptance artifact, found {len(artifacts)}")
    return artifacts[0]


def check_bundle(args):
    bundle = Path(args.check_bundle).expanduser().resolve()
    if not bundle.exists():
        raise FileNotFoundError(f"bundle not found: {bundle}")
    verify_sidecar_sha(bundle)
    with tempfile.TemporaryDirectory(prefix="lab-acceptance-check-") as td:
        extract_dir = Path(td)
        with tarfile.open(bundle, "r:*") as tar:
            safe_extract(tar, extract_dir)
        root = bundle_root(extract_dir)
        verify_internal_hashes(root)
        artifact = acceptance_from_bundle(root)
        run_verifier(args, artifact)
    print(f"ok acceptance bundle {bundle}")
    return 0


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("artifact", nargs="?", help="Acceptance directory or acceptance.json")
    parser.add_argument("--check-bundle", metavar="BUNDLE", help="Verify a .tar.gz bundle created by this command")
    parser.add_argument("--out", help="Output .tar.gz path or output directory")
    parser.add_argument("--expect-profile", choices=["cpu", "cuda", "apple", "cluster"])
    parser.add_argument("--require-run", action="store_true")
    parser.add_argument("--require-uvm-profile", action="store_true")
    parser.add_argument("--require-provenance", action="store_true")
    parser.add_argument("--require-gpu-name", action="append", default=[], metavar="SUBSTRING")
    parser.add_argument("--min-gpu-memory-mib", type=int, metavar="MIB")
    parser.add_argument("--require-compute-cap", action="append", default=[], metavar="VERSION")
    parser.add_argument("--require-cuda-sm", action="append", default=[], metavar="SM")
    parser.add_argument("--require-opencl-device", action="append", default=[], metavar="SUBSTRING")
    parser.add_argument("--require-apple-chip", action="append", default=[], metavar="SUBSTRING")
    parser.add_argument("--no-verify", action="store_true", help="Package without running lab-acceptance-verify first")
    args = parser.parse_args()

    if args.check_bundle:
        try:
            return check_bundle(args)
        except Exception as exc:
            return fail(str(exc))
    if not args.artifact:
        parser.error("artifact is required unless --check-bundle is used")

    try:
        artifact, json_path = resolve_artifact(args.artifact)
        data = json.loads(json_path.read_text())
        verify_cmd = [] if args.no_verify else run_verifier(args, artifact)
    except Exception as exc:
        return fail(str(exc))

    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    bundle_base = f"{artifact.name}-acceptance-bundle-{stamp}"
    out = output_path(args.out, bundle_base).resolve()
    out.parent.mkdir(parents=True, exist_ok=True)

    with tempfile.TemporaryDirectory(prefix="lab-acceptance-bundle-") as td:
        staging_root = Path(td) / bundle_base
        acceptance_dir = staging_root / "acceptance" / artifact.name
        shutil.copytree(artifact, acceptance_dir)

        verify_tail = []
        if args.expect_profile:
            verify_tail.extend(["--expect-profile", args.expect_profile])
        if args.require_run:
            verify_tail.append("--require-run")
        if args.require_uvm_profile:
            verify_tail.append("--require-uvm-profile")
        if args.require_provenance:
            verify_tail.append("--require-provenance")
        for gpu_name in args.require_gpu_name:
            verify_tail.extend(["--require-gpu-name", gpu_name])
        if args.min_gpu_memory_mib is not None:
            verify_tail.extend(["--min-gpu-memory-mib", str(args.min_gpu_memory_mib)])
        for compute_cap in args.require_compute_cap:
            verify_tail.extend(["--require-compute-cap", compute_cap])
        for cuda_sm in args.require_cuda_sm:
            verify_tail.extend(["--require-cuda-sm", cuda_sm])
        for opencl_device in args.require_opencl_device:
            verify_tail.extend(["--require-opencl-device", opencl_device])
        for apple_chip in args.require_apple_chip:
            verify_tail.extend(["--require-apple-chip", apple_chip])
        verify_command = "lab-acceptance-verify acceptance/{} {}".format(
            artifact.name,
            " ".join(verify_tail),
        ).strip()

        (staging_root / "README.md").write_text(
            "# Lab Acceptance Bundle\n\n"
            f"- Source artifact: `{artifact.name}`\n"
            f"- Profile: `{data.get('profile', 'unknown')}`\n"
            f"- Status: `{data.get('status', 'unknown')}`\n\n"
            "After extracting on another machine, install lab-tools and run:\n\n"
            "```bash\n"
            f"{verify_command}\n"
            "```\n",
            encoding="utf-8",
        )

        records = file_records(staging_root)
        (staging_root / "SHA256SUMS").write_text(
            "".join(f"{item['sha256']}  {item['path']}\n" for item in records),
            encoding="utf-8",
        )
        manifest = {
            "schema_version": 1,
            "generated_at": datetime.now().isoformat(timespec="seconds"),
            "artifact_name": artifact.name,
            "source_artifact": str(artifact),
            "profile": data.get("profile"),
            "status": data.get("status"),
            "steps": len(data.get("steps") or []),
            "verified": not args.no_verify,
            "verify_command": verify_cmd,
            "files": records,
        }
        (staging_root / "bundle-manifest.json").write_text(json.dumps(manifest, indent=2) + "\n", encoding="utf-8")

        with tarfile.open(out, "w:gz") as tar:
            tar.add(staging_root, arcname=bundle_base)

    digest = sha256_file(out)
    sha_path = Path(str(out) + ".sha256")
    sha_path.write_text(f"{digest}  {out.name}\n", encoding="utf-8")
    print(f"bundle={out}")
    print(f"sha256={sha_path}")
    print(f"verify={verify_command}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
