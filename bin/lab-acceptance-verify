#!/usr/bin/env python3
"""Validate a lab-host-acceptance artifact."""
import argparse
import json
import re
import sys
from pathlib import Path


COMMON_STEPS = {
    "profile",
    "doctor",
    "matrix-validate",
    "baseline-config",
    "pipeline-cpu-plan",
}

PROFILE_STEPS = {
    "cuda": {
        "rtx-smoke-dry",
        "forest-uvm-config",
        "memory-kernels-config",
        "memory-kernels-sweep-plan",
    },
    "apple": {"apple-smoke-dry"},
    "cpu": {"cpu-quick-config"},
}


def fail(message):
    print(f"error: {message}", file=sys.stderr)
    return 1


def load_artifact(path):
    p = Path(path)
    if p.is_dir():
        json_path = p / "acceptance.json"
        root = p
    else:
        json_path = p
        root = p.parent
    if not json_path.exists():
        raise FileNotFoundError(f"acceptance.json not found: {json_path}")
    return json.loads(json_path.read_text()), root, json_path


def log_exists(root, value):
    if not value:
        return False
    p = Path(value)
    if p.exists():
        return True
    return (root / p.name).exists() or (root / value).exists()


def log_path(root, value):
    if not value:
        return None
    p = Path(value)
    if p.exists():
        return p
    for candidate in (root / p.name, root / value):
        if candidate.exists():
            return candidate
    return None


def gpu_log_text(root, by_name):
    chunks = []
    for name in ("rtx-smoke-run", "rtx-smoke-dry"):
        step = by_name.get(name)
        if not step:
            continue
        path = log_path(root, step.get("log", ""))
        if path:
            chunks.append(path.read_text(errors="replace"))
    return "\n".join(chunks)


def step_log_text(root, by_name, name):
    step = by_name.get(name)
    if not step:
        return ""
    path = log_path(root, step.get("log", ""))
    if not path:
        return ""
    return path.read_text(errors="replace")


def parse_gpu_names(text):
    names = []
    for line in text.splitlines():
        m = re.match(r"\s*GPU\s+\d+:\s+(.+?)\s+\(", line)
        if m:
            names.append(m.group(1).strip())
            continue
        if "," in line and not line.lower().startswith("name,"):
            first = line.split(",", 1)[0].strip()
            if first and not first.lower().startswith(("detected=", "fail ", "ok ")):
                names.append(first)
    return names


def parse_gpu_memory_mib(text):
    values = []
    for match in re.finditer(r"(\d+)\s*MiB", text):
        values.append(int(match.group(1)))
    return values


def uvm_profile_artifacts(root):
    profile_dir = root / "profiles"
    if not profile_dir.exists():
        return []
    return [p for p in profile_dir.rglob("*") if p.is_file() and p.suffix == ".nsys-rep"]


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("artifact", help="Acceptance directory or acceptance.json")
    parser.add_argument("--expect-profile", choices=["cpu", "cuda", "apple", "cluster"])
    parser.add_argument("--require-run", action="store_true")
    parser.add_argument("--require-uvm-profile", action="store_true")
    parser.add_argument("--require-gpu-name", action="append", default=[], metavar="SUBSTRING")
    parser.add_argument("--min-gpu-memory-mib", type=int, metavar="MIB")
    parser.add_argument("--require-opencl-device", action="append", default=[], metavar="SUBSTRING")
    parser.add_argument("--require-apple-chip", action="append", default=[], metavar="SUBSTRING")
    args = parser.parse_args()

    try:
        data, root, json_path = load_artifact(args.artifact)
    except Exception as exc:
        return fail(str(exc))

    errors = []
    if data.get("schema_version") != 1:
        errors.append("schema_version must be 1")
    profile = data.get("profile")
    if args.expect_profile and profile != args.expect_profile:
        errors.append(f"profile={profile!r}, expected {args.expect_profile!r}")
    if data.get("status") != "ok":
        errors.append(f"status is not ok: {data.get('status')!r}")
    if int(data.get("failures") or 0) != 0:
        errors.append(f"failures is not zero: {data.get('failures')!r}")

    steps = data.get("steps")
    if not isinstance(steps, list):
        errors.append("steps must be a list")
        steps = []
    by_name = {str(step.get("name")): step for step in steps if isinstance(step, dict)}

    required = set(COMMON_STEPS)
    required.update(PROFILE_STEPS.get(profile, set()))
    if profile == "cuda" and args.require_run:
        required.add("rtx-smoke-run")
    if profile == "cuda" and args.require_uvm_profile:
        required.add("uvm-profile-small")
    if profile == "apple" and args.require_run:
        required.add("apple-smoke-run")

    missing = sorted(required - set(by_name))
    if missing:
        errors.append("missing steps: " + ", ".join(missing))

    for name, step in sorted(by_name.items()):
        if step.get("status") != "ok":
            errors.append(f"step {name} status={step.get('status')!r}")
        try:
            rc = int(step.get("exit_code"))
        except (TypeError, ValueError):
            errors.append(f"step {name} has invalid exit_code={step.get('exit_code')!r}")
            rc = None
        if rc not in (None, 0):
            errors.append(f"step {name} exit_code={rc}")
        if not log_exists(root, step.get("log", "")):
            errors.append(f"step {name} log missing: {step.get('log', '')}")

    if profile == "cuda" and args.require_uvm_profile:
        artifacts = uvm_profile_artifacts(root)
        if not artifacts:
            errors.append("missing copied Nsight UVM report under profiles/*.nsys-rep")

    if args.require_gpu_name or args.min_gpu_memory_mib is not None:
        if profile != "cuda":
            errors.append("GPU hardware requirements require profile='cuda'")
        text = gpu_log_text(root, by_name)
        names = parse_gpu_names(text)
        text_lower = text.lower()
        for required_name in args.require_gpu_name:
            needle = required_name.lower()
            if needle not in text_lower and not any(needle in name.lower() for name in names):
                errors.append(f"GPU name requirement not met: {required_name!r}; found {names!r}")
        if args.min_gpu_memory_mib is not None:
            memory_values = parse_gpu_memory_mib(text)
            max_memory = max(memory_values) if memory_values else 0
            if max_memory < args.min_gpu_memory_mib:
                errors.append(
                    f"GPU memory requirement not met: max {max_memory} MiB, "
                    f"required {args.min_gpu_memory_mib} MiB"
                )

    if args.require_opencl_device:
        doctor_text = step_log_text(root, by_name, "doctor")
        doctor_lower = doctor_text.lower()
        for required_device in args.require_opencl_device:
            if required_device.lower() not in doctor_lower:
                errors.append(f"OpenCL device requirement not met: {required_device!r}")
        if "warn no opencl device detected" in doctor_lower:
            errors.append("OpenCL device requirement not met: lab-doctor detected no OpenCL device")

    if args.require_apple_chip:
        if profile != "apple":
            errors.append("Apple chip requirements require profile='apple'")
        apple_text = "\n".join([
            step_log_text(root, by_name, "apple-smoke-dry"),
            step_log_text(root, by_name, "apple-smoke-run"),
        ]).lower()
        for required_chip in args.require_apple_chip:
            if required_chip.lower() not in apple_text:
                errors.append(f"Apple chip requirement not met: {required_chip!r}")

    if errors:
        for err in errors:
            print(f"error: {err}", file=sys.stderr)
        return 1

    print(f"ok acceptance {json_path} profile={profile} steps={len(steps)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
