#!/usr/bin/env bash
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
ARCHIVE_DIR="$LAB_HOME/_archives"
TARGET="${1:-latest}"

mkdir -p "$ARCHIVE_DIR"

if [ "$TARGET" = "latest" ]; then
  SUITE_DIR="$(find "$LAB_HOME" -path '*/suites/*/summary.csv' -printf '%T@ %h\n' | sort -n | tail -n 1 | cut -d' ' -f2-)"
else
  SUITE_DIR="$TARGET"
fi

if [ -z "${SUITE_DIR:-}" ] || [ ! -d "$SUITE_DIR" ]; then
  printf 'Suite directory not found: %s\n' "${TARGET:-}" >&2
  exit 2
fi

EXPERIMENT="$(basename "$(dirname "$(dirname "$SUITE_DIR")")")"
SUITE_ID="$(basename "$SUITE_DIR")"
OUT="$ARCHIVE_DIR/${EXPERIMENT}-${SUITE_ID}.tar.zst"

if command -v zstd >/dev/null 2>&1; then
  tar --zstd -cf "$OUT" -C "$(dirname "$SUITE_DIR")" "$SUITE_ID"
else
  OUT="${OUT%.zst}.gz"
  tar -czf "$OUT" -C "$(dirname "$SUITE_DIR")" "$SUITE_ID"
fi

sha256sum "$OUT" > "$OUT.sha256"
printf '%s\n' "$OUT"
