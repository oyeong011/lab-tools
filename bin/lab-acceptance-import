#!/usr/bin/env python3
"""Import staged acceptance bundles from Google Drive, USB, or a shared folder."""
import argparse
import hashlib
import json
import shutil
import subprocess
import sys
from pathlib import Path


def fail(message):
    print(f"error: {message}", file=sys.stderr)
    return 1


def sha256_file(path):
    h = hashlib.sha256()
    with Path(path).open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def tool_path(name):
    local = Path(__file__).resolve().parent / name
    if local.exists():
        return str(local)
    found = shutil.which(name)
    if found:
        return found
    raise FileNotFoundError(f"{name} not found in checkout or PATH")


def default_config_path():
    repo_config = Path(__file__).resolve().parent.parent / "config" / "acceptance" / "required-hosts.json"
    if repo_config.exists():
        return repo_config
    return Path.home() / ".config" / "lab" / "acceptance" / "required-hosts.json"


def discover_bundles(source, recursive):
    root = Path(source).expanduser()
    if not root.is_dir():
        raise NotADirectoryError(f"source directory not found: {root}")
    bundles = []
    for pattern in ("*.tar.gz", "*.tgz"):
        found = root.rglob(pattern) if recursive else root.glob(pattern)
        bundles.extend(path.resolve() for path in found if path.is_file())
    return sorted(set(bundles), key=lambda p: (p.stat().st_mtime, str(p)), reverse=True)


def sidecar_for(bundle):
    return Path(str(bundle) + ".sha256")


def verify_sidecar(bundle):
    sidecar = sidecar_for(bundle)
    if not sidecar.exists():
        raise FileNotFoundError(f"sidecar sha256 not found: {sidecar}")
    expected = sidecar.read_text(encoding="utf-8").split()[0]
    actual = sha256_file(bundle)
    if expected != actual:
        raise ValueError(f"bundle sha256 mismatch for {bundle.name}: expected {expected}, got {actual}")
    return sidecar


def staged_config_path(source, config_arg):
    if config_arg:
        return Path(config_arg).expanduser().resolve()
    manifest_path = Path(source).expanduser() / "STAGE-MANIFEST.json"
    if manifest_path.exists():
        manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
        staged = (manifest.get("staged_config") or {}).get("path")
        if staged:
            candidate = Path(source).expanduser() / staged
            if candidate.exists():
                return candidate.resolve()
    staged = Path(source).expanduser() / "required-hosts.json"
    if staged.exists():
        return staged.resolve()
    return default_config_path().expanduser().resolve()


def copy_file(src, out_dir, dry_run):
    dst = out_dir / src.name
    if dry_run:
        return {"source": str(src), "path": dst.name, "copied": False, "dry_run": True}
    if src.resolve() != dst.resolve():
        shutil.copy2(src, dst)
        copied = True
    else:
        copied = False
    return {
        "source": str(src),
        "path": dst.name,
        "bytes": dst.stat().st_size,
        "sha256": sha256_file(dst),
        "copied": copied,
    }


def run_matrix(config, out_dir, targets):
    cmd = [tool_path("lab-acceptance-matrix"), "--config", str(config), "--bundle-dir", str(out_dir)]
    for target in targets:
        cmd.extend(["--target", target])
    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("source", help="Stage directory containing .tar.gz bundles and .sha256 sidecars")
    parser.add_argument("--out", default=str(Path.home() / "lab" / "_acceptance_bundles"))
    parser.add_argument("--config", help="Acceptance matrix JSON; defaults to source/required-hosts.json when present")
    parser.add_argument("--target", action="append", default=[], help="Pass one target filter to lab-acceptance-matrix")
    parser.add_argument("--recursive", action="store_true", help="Recursively search source for bundles")
    parser.add_argument("--dry-run", action="store_true", help="Print the import plan without copying")
    parser.add_argument("--strict", action="store_true", help="Exit nonzero unless the post-import matrix is complete")
    parser.add_argument("--json", action="store_true", help="Print machine-readable import summary")
    args = parser.parse_args()

    try:
        source = Path(args.source).expanduser().resolve()
        out_dir = Path(args.out).expanduser().resolve()
        config = staged_config_path(source, args.config)
        if not config.exists():
            raise FileNotFoundError(f"acceptance config not found: {config}")
        bundles = discover_bundles(source, args.recursive)
        if not bundles:
            raise FileNotFoundError(f"no acceptance bundles found in {source}")
        records = []
        for bundle in bundles:
            sidecar = verify_sidecar(bundle)
            records.append((bundle, sidecar))
        if not args.dry_run:
            out_dir.mkdir(parents=True, exist_ok=True)
        imported = []
        for bundle, sidecar in records:
            imported.append(copy_file(bundle, out_dir, args.dry_run))
            imported.append(copy_file(sidecar, out_dir, args.dry_run))
        staged_config = copy_file(config, out_dir, args.dry_run)
        matrix = None
        if not args.dry_run:
            matrix_config = out_dir / staged_config["path"]
            matrix = run_matrix(matrix_config, out_dir, args.target)
    except Exception as exc:
        return fail(str(exc))

    summary = {
        "schema_version": 1,
        "source": str(source),
        "out_dir": str(out_dir),
        "config": str(config),
        "staged_config": staged_config,
        "bundles": len(records),
        "files": imported,
        "matrix_returncode": None if matrix is None else matrix.returncode,
    }
    if args.json:
        if matrix is not None:
            summary["matrix_output"] = matrix.stdout
        print(json.dumps(summary, indent=2) + "\n", end="")
    else:
        print(f"source={source}")
        print(f"out_dir={out_dir}")
        print(f"imported_bundles={len(records)}")
        print(f"imported_files={len(imported)}")
        print(f"config={staged_config['path']}")
        if matrix is not None:
            print(matrix.stdout, end="")

    if args.strict and matrix is not None and matrix.returncode != 0:
        return matrix.returncode
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
