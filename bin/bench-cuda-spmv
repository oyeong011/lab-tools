#!/usr/bin/env bash
set -euo pipefail

LAB_HOME="${LAB_HOME:-$HOME/lab}"
ROWS="${1:-${LAB_SPMV_ROWS:-1048576}}"
NNZ_PER_ROW="${2:-${LAB_SPMV_NNZ_PER_ROW:-16}}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SRC="$SCRIPT_DIR/../config/cuda-memory-kernels.cu"
if [ ! -f "$SRC" ]; then
  SRC="$HOME/.config/lab/cuda-memory-kernels.cu"
fi
BUILD_DIR="$LAB_HOME/_benchmarks/cuda"
BIN="$BUILD_DIR/cuda-memory-kernels"
OUT="$BUILD_DIR/cuda-spmv-${ROWS}x${NNZ_PER_ROW}-$(date +%Y%m%d-%H%M%S).txt"

if ! command -v nvcc >/dev/null 2>&1; then
  printf 'nvcc not available — install CUDA toolkit or run inside lab-cuda container.\n' >&2
  exit 127
fi

mkdir -p "$BUILD_DIR"
ARCH_FLAGS=()
if command -v lab-cuda-arch-flags >/dev/null 2>&1; then
  while IFS= read -r flag; do
    [ -n "$flag" ] && ARCH_FLAGS+=("$flag")
  done < <(lab-cuda-arch-flags)
fi
if [ ! -x "$BIN" ] || [ "$SRC" -nt "$BIN" ]; then
  printf 'Build nvcc_arch_flags=%s\n' "${ARCH_FLAGS[*]:-<default>}"
  nvcc -O2 "${ARCH_FLAGS[@]}" "$SRC" -o "$BIN"
  printf 'Build: compiled %s\n' "$BIN"
else
  printf 'Build: reused %s\n' "$BIN"
fi
"$BIN" spmv "$ROWS" "$NNZ_PER_ROW" | tee "$OUT"
printf '\nSaved: %s\n' "$OUT"
